@@ -0,0 +1,44 @@
+import { mkdtempSync, readFileSync, rmSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { join } from "node:path";
+import { fauxAssistantMessage } from "@earendil-works/pi-ai";
+import { afterEach, describe, expect, it } from "vitest";
+import { SessionManager } from "../../../src/core/session-manager.ts";
+import { createHarness, type Harness } from "../harness.ts";
+
+describe("regression #44: eager downstream session header", () => {
+	const harnesses: Harness[] = [];
+	const roots: string[] = [];
+
+	afterEach(() => {
+		while (harnesses.length > 0) harnesses.pop()?.cleanup();
+		while (roots.length > 0) rmSync(roots.pop()!, { recursive: true, force: true });
+	});
+
+	it("uses the fail-closed downstream header when an Agent Thread never defers", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-ordinary-downstream-session-"));
+		roots.push(root);
+		const sessionManager = SessionManager.create(root, join(root, "sessions"));
+		const harness = await createHarness({ sessionManager });
+		harnesses.push(harness);
+		harness.setResponses([fauxAssistantMessage("Ordinary response")]);
+
+		await harness.session.prompt("Ordinary prompt");
+
+		const sessionFile = sessionManager.getSessionFile();
+		expect(sessionFile).toBeDefined();
+		const [header] = readFileSync(sessionFile!, "utf8")
+			.trim()
+			.split("\n")
+			.map((line) => JSON.parse(line));
+		expect(header).toEqual({
+			type: "dev.taylorrowser.pi-wait-for-user/session",
+			version: 1,
+			basedOnPiSessionVersion: 3,
+			id: sessionManager.getSessionId(),
+			timestamp: expect.any(String),
+			cwd: root,
+		});
+		expect(sessionManager.getEntries().some((entry) => entry.type === "tool_batch_deferred")).toBe(false);
+	});
+});
