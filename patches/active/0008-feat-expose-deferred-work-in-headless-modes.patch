+						? { ...event, deferredBatch: event.deferredBatch ?? null }
+						: event;
+				writeRawStdout(`${JSON.stringify(outputEvent)}\n`);
 			}
 		});
 	};
@@ -114,16 +134,25 @@ export async function runPrintMode(runtimeHost: AgentSessionRuntime, options: Pr
 			if (header) {
