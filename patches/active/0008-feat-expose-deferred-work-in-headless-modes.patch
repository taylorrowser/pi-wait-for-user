+++ b/packages/coding-agent/test/suite/regressions/20-rpc-client-deferred.test.ts
@@ -0,0 +1,59 @@
+import { describe, expect, it, vi } from "vitest";
+import { RpcClient, RpcClientError } from "../../../src/modes/rpc/rpc-client.ts";
+
+type RpcClientPrivate = {
+	send: (command: { type: string }) => Promise<unknown>;
+	getData: <T>(response: unknown) => T;
+};
+
+describe("RpcClient deferred work", () => {
+	it("exposes capability discovery and argument-free advancement", async () => {
+		const client = new RpcClient();
+		const privateClient = client as unknown as RpcClientPrivate;
+		const send = vi.fn(async (command: { type: string }) => ({
+			type: "response",
+			command: command.type,
+			success: true,
+			data:
+				command.type === "get_capabilities"
+					? { deferredToolBatches: { protocolVersions: [1], operations: ["resume", "abandon"] } }
+					: { status: "advanced", deferredBatch: null },
+		}));
+		privateClient.send = send;
+		privateClient.getData = <T>(response: unknown): T => (response as { data: T }).data;
+
+		await expect(client.getCapabilities()).resolves.toEqual({
+			deferredToolBatches: { protocolVersions: [1], operations: ["resume", "abandon"] },
+		});
+		await expect(client.resumeDeferred()).resolves.toEqual({ status: "advanced", deferredBatch: undefined });
+		await expect(client.abandonDeferred()).resolves.toEqual({ status: "advanced", deferredBatch: undefined });
+		expect(send).toHaveBeenNthCalledWith(1, { type: "get_capabilities" });
+		expect(send).toHaveBeenNthCalledWith(2, { type: "resume_deferred" });
+		expect(send).toHaveBeenNthCalledWith(3, { type: "abandon_deferred" });
+	});
+
+	it("preserves machine-readable failure details", () => {
+		const client = new RpcClient();
+		const privateClient = client as unknown as RpcClientPrivate;
+		let thrown: unknown;
+		try {
+			privateClient.getData({
+				type: "response",
+				command: "steer",
+				success: false,
+				error: "Agent is waiting",
+				errorCode: "agent_waiting",
+				data: { deferredBatch: { kind: "invalid", code: "marker_mismatch", message: "Invalid" } },
+			});
+		} catch (error) {
+			thrown = error;
+		}
+
+		expect(thrown).toBeInstanceOf(RpcClientError);
+		expect(thrown).toMatchObject({
+			message: "Agent is waiting",
+			errorCode: "agent_waiting",
+			deferredBatch: { kind: "invalid", code: "marker_mismatch" },
+		});
+	});
+});
diff --git a/packages/coding-agent/test/suite/regressions/20-rpc-deferred-mode.test.ts b/packages/coding-agent/test/suite/regressions/20-rpc-deferred-mode.test.ts
new file mode 100644
index 00000000..16cc2adb
--- /dev/null
+++ b/packages/coding-agent/test/suite/regressions/20-rpc-deferred-mode.test.ts
@@ -0,0 +1,205 @@
+import { mkdtempSync, rmSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { join } from "node:path";
+import { fauxAssistantMessage } from "@earendil-works/pi-ai";
+import { afterEach, beforeEach, describe, expect, it, vi } from "vitest";
+import type { AgentSessionRuntime } from "../../../src/core/agent-session-runtime.ts";
+import { SessionManager } from "../../../src/core/session-manager.ts";
+import { runRpcMode } from "../../../src/modes/rpc/rpc-mode.ts";
+import {
+	deferredToolBatchMessage,
+	type InteractionRequestTestController,
+	questionExtension,
+} from "../deferred-tool-batch-fixture.ts";
+import { createHarness, type Harness } from "../harness.ts";
+
+const rpcIo = vi.hoisted(() => ({
+	outputLines: [] as string[],
+	lineHandler: undefined as ((line: string) => void) | undefined,
+}));
+
+vi.mock("../../../src/core/output-guard.js", () => ({
+	flushRawStdout: vi.fn(async () => {}),
+	takeOverStdout: vi.fn(),
+	waitForRawStdoutBackpressure: vi.fn(async () => {}),
+	writeRawStdout: (line: string) => rpcIo.outputLines.push(line),
+}));
+
+vi.mock("../../../src/modes/interactive/theme/theme.js", () => ({ theme: {} }));
+
+vi.mock("../../../src/modes/rpc/jsonl.js", () => ({
+	attachJsonlLineReader: vi.fn((_stream: NodeJS.ReadableStream, onLine: (line: string) => void) => {
+		rpcIo.lineHandler = onLine;
+		return () => {};
+	}),
+	serializeJsonLine: (value: unknown) => `${JSON.stringify(value)}\n`,
+}));
+
+type NodeListener = Parameters<typeof process.on>[1];
+
+type ListenerSnapshot = {
+	stdinEnd: NodeListener[];
+	signals: Map<NodeJS.Signals, NodeListener[]>;
+};
+
+function takeListenerSnapshot(): ListenerSnapshot {
+	const signals: NodeJS.Signals[] = process.platform === "win32" ? ["SIGTERM"] : ["SIGTERM", "SIGHUP"];
+	return {
+		stdinEnd: process.stdin.listeners("end") as NodeListener[],
+		signals: new Map(signals.map((signal) => [signal, process.listeners(signal) as NodeListener[]])),
+	};
+}
+
+function restoreListeners(snapshot: ListenerSnapshot): void {
+	for (const listener of process.stdin.listeners("end") as NodeListener[]) {
+		if (!snapshot.stdinEnd.includes(listener)) process.stdin.off("end", listener);
+	}
+	for (const [signal, previousListeners] of snapshot.signals) {
+		for (const listener of process.listeners(signal) as NodeListener[]) {
+			if (!previousListeners.includes(listener)) process.off(signal, listener);
+		}
+	}
+}
+
+function outputRecords(): Array<Record<string, unknown>> {
+	return rpcIo.outputLines.map((line) => JSON.parse(line) as Record<string, unknown>);
+}
+
+async function send(command: Record<string, unknown>): Promise<Record<string, unknown>> {
+	rpcIo.lineHandler?.(JSON.stringify(command));
+	await vi.waitFor(() => {
+		expect(outputRecords().some((record) => record.type === "response" && record.id === command.id)).toBe(true);
+	});
+	return outputRecords().find((record) => record.type === "response" && record.id === command.id)!;
+}
+
+function runtimeFor(harness: Harness): AgentSessionRuntime {
+	return {
+		session: harness.session,
+		setRebindSession: vi.fn(),
+		newSession: vi.fn(async () => ({ cancelled: true })),
+		switchSession: vi.fn(async () => ({ cancelled: true })),
+		fork: vi.fn(async () => ({ cancelled: true, selectedText: "" })),
+		dispose: vi.fn(async () => {}),
+	} as unknown as AgentSessionRuntime;
+}
+
+describe("RPC deferred work", () => {
+	let harness: Harness | undefined;
+	let listenerSnapshot: ListenerSnapshot;
+	let root: string | undefined;
+
+	beforeEach(() => {
+		listenerSnapshot = takeListenerSnapshot();
+	});
+
+	afterEach(() => {
+		harness?.cleanup();
+		restoreListeners(listenerSnapshot);
+		if (root) rmSync(root, { recursive: true, force: true });
+		rpcIo.outputLines = [];
+		rpcIo.lineHandler = undefined;
+	});
+
+	it("reports the neutral deferred snapshot and exact process capabilities", async () => {
+		root = mkdtempSync(join(tmpdir(), "pi-rpc-deferred-"));
+		harness = await createHarness({
+			sessionManager: SessionManager.create(root, join(root, "sessions")),
+			extensionFactories: [questionExtension([])],
+		});
+		harness.setResponses([deferredToolBatchMessage()]);
+		await harness.session.prompt("Ask before shipping");
+
+		void runRpcMode(runtimeFor(harness));
+		await vi.waitFor(() => expect(rpcIo.lineHandler).toBeDefined());
+
+		const state = await send({ id: "state", type: "get_state" });
+		expect(state).toMatchObject({
+			success: true,
+			data: {
+				deferredBatch: {
+					kind: "batch",
+					phase: "deferred",
+					ownerCallId: "call-1",
+					correlationId: "request-1",
+				},
+			},
+		});
+
+		const capabilities = await send({ id: "capabilities", type: "get_capabilities" });
+		expect(capabilities).toEqual({
+			id: "capabilities",
+			type: "response",
+			command: "get_capabilities",
+			success: true,
+			data: {
+				deferredToolBatches: { protocolVersions: [1], operations: ["resume", "abandon"] },
+			},
+		});
+
+		const entriesBeforeAbort = harness.sessionManager.getEntries();
+		expect(await send({ id: "abort", type: "abort" })).toMatchObject({ success: true });
+		expect(harness.sessionManager.getEntries()).toEqual(entriesBeforeAbort);
+		expect(await send({ id: "state-after-abort", type: "get_state" })).toMatchObject({
+			success: true,
+			data: { deferredBatch: { kind: "batch", phase: "deferred" } },
+		});
+	});
+
+	it("responds after deferred advancement settles and emits explicit replacement state", async () => {
+		root = mkdtempSync(join(tmpdir(), "pi-rpc-resume-"));
+		const controller: InteractionRequestTestController = {};
+		harness = await createHarness({
+			sessionManager: SessionManager.create(root, join(root, "sessions")),
+			extensionFactories: [questionExtension([], controller)],
+		});
+		harness.setResponses([deferredToolBatchMessage()]);
+		await harness.session.prompt("Ask before shipping");
+		controller.recordResponse?.("Yes");
+		harness.setResponses([fauxAssistantMessage("Continued")]);
+
+		void runRpcMode(runtimeFor(harness));
+		await vi.waitFor(() => expect(rpcIo.lineHandler).toBeDefined());
+
+		const response = await send({ id: "resume", type: "resume_deferred" });
+		expect(response).toEqual({
+			id: "resume",
+			type: "response",
+			command: "resume_deferred",
+			success: true,
+			data: { status: "advanced", deferredBatch: null },
+		});
+		const records = outputRecords();
+		expect(records.filter((record) => record.type === "deferred_batch_changed").at(-1)).toEqual({
+			type: "deferred_batch_changed",
+			deferredBatch: null,
+		});
+		expect(records.findIndex((record) => record.type === "agent_settled")).toBeLessThan(
+			records.findIndex((record) => record.id === "resume"),
+		);
+	});
+
+	it("returns machine-readable Waiting State failures with the current snapshot", async () => {
+		root = mkdtempSync(join(tmpdir(), "pi-rpc-waiting-error-"));
+		harness = await createHarness({
+			sessionManager: SessionManager.create(root, join(root, "sessions")),
+			extensionFactories: [questionExtension([])],
+		});
+		harness.setResponses([deferredToolBatchMessage()]);
+		await harness.session.prompt("Ask before shipping");
+
+		void runRpcMode(runtimeFor(harness));
+		await vi.waitFor(() => expect(rpcIo.lineHandler).toBeDefined());
+
+		const response = await send({ id: "steer", type: "steer", message: "Do something else" });
+		expect(response).toMatchObject({
+			id: "steer",
+			type: "response",
+			command: "steer",
+			success: false,
+			error: expect.any(String),
+			errorCode: "agent_waiting",
+			data: { deferredBatch: { kind: "batch", phase: "deferred", ownerCallId: "call-1" } },
+		});
+	});
+});
