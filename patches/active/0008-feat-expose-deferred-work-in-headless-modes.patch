+function formatDeferredBatch(deferredBatch: DeferredBatchSnapshot): string {
+	if (deferredBatch.kind === "invalid") {
+		return `Deferred work unavailable: ${deferredBatch.message}`;
+	}
+	const ownerName =
+		deferredBatch.calls.find((call) => call.toolCallId === deferredBatch.ownerCallId)?.toolName ??
+		deferredBatch.ownerCallId;
+	if (deferredBatch.availability.status === "unavailable") {
+		const reasons = [...new Set(deferredBatch.availability.reasons.map((reason) => reason.message))];
+		return `Waiting unavailable: ${reasons.join("; ")} (session ${deferredBatch.sessionId}).`;
+	}
+	const callCount = deferredBatch.calls.length;
+	return `Waiting: ${ownerName} in session ${deferredBatch.sessionId} (${callCount} call${callCount === 1 ? "" : "s"} held).`;
+}
+
 /**
  * Run in print (single-shot) mode.
  * Sends prompts to the agent and outputs the result.
