index 00000000..e5b8c6fa
--- /dev/null
+++ b/packages/coding-agent/test/suite/regressions/20-print-json-deferred-modes.test.ts
@@ -0,0 +1,127 @@
+import { mkdtempSync, rmSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { join } from "node:path";
+import { afterEach, describe, expect, it, vi } from "vitest";
+import type { AgentSessionRuntime } from "../../../src/core/agent-session-runtime.ts";
+import { SessionManager } from "../../../src/core/session-manager.ts";
+import { runPrintMode } from "../../../src/modes/print-mode.ts";
+import { deferredToolBatchMessage, questionExtension } from "../deferred-tool-batch-fixture.ts";
+import { createHarness, getUserTexts, type Harness } from "../harness.ts";
+
+const stdout = vi.hoisted(() => ({ chunks: [] as string[] }));
+
+vi.mock("../../../src/core/output-guard.js", () => ({
+	flushRawStdout: vi.fn(async () => {}),
+	writeRawStdout: (chunk: string) => stdout.chunks.push(chunk),
+}));
+
+function runtimeFor(harness: Harness): AgentSessionRuntime {
+	return {
+		session: harness.session,
+		setRebindSession: vi.fn(),
+		newSession: vi.fn(async () => ({ cancelled: true })),
+		switchSession: vi.fn(async () => ({ cancelled: true })),
+		fork: vi.fn(async () => ({ cancelled: true, selectedText: "" })),
+		dispose: vi.fn(async () => {}),
+	} as unknown as AgentSessionRuntime;
+}
+
+describe("print modes with deferred work", () => {
+	let harness: Harness | undefined;
+	let root: string | undefined;
+
+	afterEach(() => {
+		harness?.cleanup();
+		if (root) rmSync(root, { recursive: true, force: true });
+		stdout.chunks = [];
+	});
+
+	it("preserves assistant text and prints a privacy-safe Waiting line", async () => {
+		root = mkdtempSync(join(tmpdir(), "pi-print-deferred-"));
+		harness = await createHarness({
+			sessionManager: SessionManager.create(root, join(root, "sessions")),
+			extensionFactories: [questionExtension([])],
+		});
+		const response = deferredToolBatchMessage();
+		response.content.unshift({ type: "text", text: "I need confirmation." });
+		harness.setResponses([response]);
+		await harness.session.prompt("Ask before shipping");
+
+		const exitCode = await runPrintMode(runtimeFor(harness), { mode: "text" });
+
+		expect(exitCode).toBe(0);
+		expect(stdout.chunks.join("")).toBe(
+			`I need confirmation.\nWaiting: question in session ${harness.session.sessionId} (3 calls held).\n`,
+		);
+		expect(stdout.chunks.join("")).not.toContain("Ship?");
+		expect(stdout.chunks.join("")).not.toContain("request-1");
+	});
+
+	it("emits initial JSON deferred state immediately after the session header", async () => {
+		root = mkdtempSync(join(tmpdir(), "pi-json-deferred-"));
+		harness = await createHarness({
+			sessionManager: SessionManager.create(root, join(root, "sessions")),
+			extensionFactories: [questionExtension([])],
+		});
+		harness.setResponses([deferredToolBatchMessage()]);
+		await harness.session.prompt("Ask before shipping");
+
+		const exitCode = await runPrintMode(runtimeFor(harness), { mode: "json" });
+		const records = stdout.chunks.map((line) => JSON.parse(line) as Record<string, unknown>);
+
+		expect(exitCode).toBe(0);
+		expect(records[0]).toMatchObject({ type: "dev.taylorrowser.pi-wait-for-user/session" });
+		expect(records[1]).toMatchObject({
+			type: "deferred_batch_state",
+			deferredBatch: { kind: "batch", phase: "deferred", ownerCallId: "call-1" },
+		});
+	});
+
+	it("stops before later supplied prompts after reaching durable deferral", async () => {
+		root = mkdtempSync(join(tmpdir(), "pi-json-stop-prompts-"));
+		harness = await createHarness({
+			sessionManager: SessionManager.create(root, join(root, "sessions")),
+			extensionFactories: [questionExtension([])],
+		});
+		harness.setResponses([deferredToolBatchMessage()]);
+
+		const exitCode = await runPrintMode(runtimeFor(harness), {
+			mode: "json",
+			initialMessage: "first",
+			messages: ["second", "third"],
+		});
+		const records = stdout.chunks.map((line) => JSON.parse(line) as Record<string, unknown>);
+
+		expect(exitCode).toBe(0);
+		expect(getUserTexts(harness)).toEqual(["first"]);
+		expect(records).toContainEqual(
+			expect.objectContaining({
+				type: "deferred_batch_changed",
+				deferredBatch: expect.objectContaining({ kind: "batch", phase: "deferred" }),
+			}),
+		);
+		expect(records.some((record) => record.type === "extension_ui_request")).toBe(false);
+	});
+
+	it("prints concise unavailable reasons and still exits successfully", async () => {
+		root = mkdtempSync(join(tmpdir(), "pi-print-unavailable-"));
+		harness = await createHarness({
+			sessionManager: SessionManager.create(root, join(root, "sessions")),
+			extensionFactories: [questionExtension([])],
+		});
+		harness.setResponses([deferredToolBatchMessage()]);
+		await harness.session.prompt("Ask before shipping");
+		harness.session.setActiveToolsByName(["question"]);
+
+		const exitCode = await runPrintMode(runtimeFor(harness), { mode: "text" });
+		const output = stdout.chunks.join("");
+
+		expect(exitCode).toBe(0);
+		expect(output).toContain("Waiting unavailable:");
+		expect(output).toContain("Held tool ordinary is not currently active.");
+		expect(output.match(/Held tool ordinary is not currently active\./g)).toHaveLength(1);
+		expect(output).toContain(`session ${harness.session.sessionId}`);
+		expect(output).not.toContain("Prepare?");
+		expect(output).not.toContain("Deploy?");
+	});
+});
diff --git a/packages/coding-agent/test/suite/regressions/20-rpc-client-deferred.test.ts b/packages/coding-agent/test/suite/regressions/20-rpc-client-deferred.test.ts
