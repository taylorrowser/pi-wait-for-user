+				writeRawStdout(
+					`${JSON.stringify({ type: "deferred_batch_state", deferredBatch: session.deferredBatch })}\n`,
+				);
+			}
 		}
 
 		await rebindSession();
 
+		let reachedDeferredState = false;
 		if (initialMessage) {
 			await session.prompt(initialMessage, { images: initialImages });
+			reachedDeferredState = session.deferredBatch !== undefined;
 		}
 
 		for (const message of messages) {
+			if (reachedDeferredState) break;
 			await session.prompt(message);
+			reachedDeferredState = session.deferredBatch !== undefined;
 		}
 
 		if (mode === "text") {
@@ -143,6 +172,9 @@ export async function runPrintMode(runtimeHost: AgentSessionRuntime, options: Pr
 					}
 				}
 			}
+			if (session.deferredBatch) {
+				writeRawStdout(`${formatDeferredBatch(session.deferredBatch)}\n`);
+			}
 		}
 
 		return exitCode;
