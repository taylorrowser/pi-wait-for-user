diff --git a/packages/coding-agent/test/suite/regressions/45-live-unavailable-resolver.test.ts b/packages/coding-agent/test/suite/regressions/45-live-unavailable-resolver.test.ts
new file mode 100644
index 00000000..b686c570
--- /dev/null
+++ b/packages/coding-agent/test/suite/regressions/45-live-unavailable-resolver.test.ts
@@ -0,0 +1,57 @@
+import { mkdtempSync, readFileSync, rmSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { join } from "node:path";
+import { fauxAssistantMessage, fauxToolCall } from "@earendil-works/pi-ai";
+import { afterEach, describe, expect, it } from "vitest";
+import { SessionManager } from "../../../src/core/session-manager.ts";
+import { type InteractionRequestTestController, questionExtension } from "../deferred-tool-batch-fixture.ts";
+import { createHarness, type Harness } from "../harness.ts";
+
+describe("regression #45: unavailable live resolver", () => {
+	const harnesses: Harness[] = [];
+	const roots: string[] = [];
+
+	afterEach(() => {
+		while (harnesses.length > 0) harnesses.pop()?.cleanup();
+		while (roots.length > 0) rmSync(roots.pop()!, { recursive: true, force: true });
+	});
+
+	it("fails closed without appending a synthetic assistant failure", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-live-unavailable-resolver-"));
+		roots.push(root);
+		const manager = SessionManager.create(root, join(root, "sessions"));
+		const controller: InteractionRequestTestController = { resolverFailure: "unavailable" };
+		let bytesBeforeFailure: string | undefined;
+		const harness = await createHarness({
+			sessionManager: manager,
+			extensionFactories: [
+				questionExtension([], controller, {
+					beforeResolverFailure: () => {
+						bytesBeforeFailure = readFileSync(manager.getSessionFile()!, "utf8");
+					},
+				}),
+			],
+		});
+		harnesses.push(harness);
+		harness.setResponses([
+			fauxAssistantMessage(fauxToolCall("question", { question: "Ship?" }, { id: "call-1" }), {
+				stopReason: "toolUse",
+			}),
+		]);
+
+		await expect(harness.session.prompt("Ask before shipping")).rejects.toMatchObject({
+			code: "resolver_error",
+			message: "package unavailable",
+		});
+
+		expect(bytesBeforeFailure).toBeDefined();
+		expect(readFileSync(manager.getSessionFile()!, "utf8")).toBe(bytesBeforeFailure);
+		expect(manager.getBranch().map((entry) => entry.type)).toEqual(["message", "message", "custom"]);
+		expect(manager.getBranch().flatMap((entry) => (entry.type === "message" ? [entry.message.role] : []))).toEqual([
+			"user",
+			"assistant",
+		]);
+		expect(harness.events.some((event) => event.type === "tool_execution_start")).toBe(false);
+		expect(harness.events.some((event) => event.type === "turn_end")).toBe(false);
+	});
+});
