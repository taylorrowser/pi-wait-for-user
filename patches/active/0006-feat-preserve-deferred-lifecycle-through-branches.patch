 	// Compaction
 	// =========================================================================
 
+	private _getCompactionPinnedEntryId(): string | undefined {
+		const deferred = this.deferredBatch;
+		return deferred?.kind === "batch" && deferred.phase !== "continuation" ? deferred.assistantEntryId : undefined;
+	}
+
+	private _assertCompactionPinnedTailFits(pathEntries: SessionEntry[], keepRecentTokens: number): void {
+		const pinnedEntryId = this._getCompactionPinnedEntryId();
+		if (!pinnedEntryId) return;
+		const pinnedIndex = pathEntries.findIndex((entry) => entry.id === pinnedEntryId);
+		if (pinnedIndex < 0) return;
+		const pinnedTokens = pathEntries
+			.slice(pinnedIndex)
+			.flatMap(sessionEntryToContextMessages)
+			.reduce((total, message) => total + estimateTokens(message), 0);
+		if (pinnedTokens > keepRecentTokens) {
+			throw new Error("Cannot compact while deferred: the pinned tool batch exceeds the retained context budget");
+		}
+	}
+
+	private _clampCompactionFirstKeptEntryId(pathEntries: SessionEntry[], firstKeptEntryId: string): string {
+		const pinnedEntryId = this._getCompactionPinnedEntryId();
+		if (!pinnedEntryId) return firstKeptEntryId;
+		const ownerIndex = pathEntries.findIndex((entry) => entry.id === pinnedEntryId);
+		const proposedIndex = pathEntries.findIndex((entry) => entry.id === firstKeptEntryId);
+		return ownerIndex >= 0 && (proposedIndex < 0 || proposedIndex > ownerIndex) ? pinnedEntryId : firstKeptEntryId;
+	}
+
 	/**
 	 * Manually compact the session context.
 	 * Aborts current agent operation first.
