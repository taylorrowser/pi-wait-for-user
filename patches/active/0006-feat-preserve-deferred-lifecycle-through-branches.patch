diff --git a/packages/coding-agent/src/core/deferred-batch.ts b/packages/coding-agent/src/core/deferred-batch.ts
index 939d32ff..a92ec92d 100644
--- a/packages/coding-agent/src/core/deferred-batch.ts
+++ b/packages/coding-agent/src/core/deferred-batch.ts
@@ -78,6 +78,24 @@ function invalid(code: InvalidDeferredBatch["code"], message: string): InvalidDe
 	return { kind: "invalid", code, message };
 }
 
+function inspectGlobalCorrelations(entries: SessionEntry[]): InvalidDeferredBatch | undefined {
+	const correlationByProvenance = new Map<string, string>();
+	for (const entry of entries) {
+		if (entry.type !== "tool_batch_deferred") continue;
+		const provenance = `${entry.assistantEntryId}\u0000${entry.ownerCallId}`;
+		const correlation = `${entry.handlerId}\u0000${entry.correlationId}`;
+		const existingCorrelation = correlationByProvenance.get(provenance);
+		if (existingCorrelation !== undefined && existingCorrelation !== correlation) {
+			return invalid(
+				"conflicting_correlation",
+				`Deferred owner ${entry.ownerCallId} has a conflicting request mapping in this session`,
+			);
+		}
+		correlationByProvenance.set(provenance, correlation);
+	}
+	return undefined;
+}
+
 function assistantBatches(branch: SessionEntry[]): Map<string, AssistantBatch> {
 	const batches = new Map<string, AssistantBatch>();
 	for (let entryIndex = 0; entryIndex < branch.length; entryIndex++) {
@@ -281,6 +299,8 @@ export function reconstructDeferredBatch(
 	sessionManager: SessionManager,
 	tools: readonly AgentTool[],
 ): DeferredBatchSnapshot | undefined {
+	const correlationConflict = inspectGlobalCorrelations(sessionManager.getEntries());
+	if (correlationConflict) return correlationConflict;
 	const branch = sessionManager.getBranch();
 	const batches = assistantBatches(branch);
 	const results = recordedResults(branch);
