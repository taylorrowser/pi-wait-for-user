+		: never,
+): PresentationContext {
+	const extensionContext = {} as ExtensionContext;
+	return {
+		session: {
+			deferredBatch: SNAPSHOT,
+			getToolDefinition: () =>
+				({
+					name: "question",
+					label: "Question",
+					description: "Question",
+					parameters: {} as never,
+					deferral: presenter
+						? {
+								handlerId: "dev.example.question",
+								handlerVersion: 1,
+								resumableHandlerVersions: [1],
+								resolve: async () => ({ status: "deferred", correlationId: "request-21" }),
+								presenter,
