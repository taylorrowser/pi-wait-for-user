+			label: "Question",
+			description: "Question",
+			parameters: Type.Any(),
+			execute: async () => ({ content: [], details: {} }),
+			renderCall: (_args, _theme, context) =>
+				new Text(context.deferredState === "owner" ? "Package waiting" : "Question", 0, 0),
+		};
+		const owner = new ToolExecutionComponent("question", "call-owner", {}, {}, definition, tui, process.cwd());
+		const sibling = new ToolExecutionComponent("ordinary", "call-sibling", {}, {}, undefined, tui, process.cwd());
+		const context = {
+			session: { deferredBatch: SNAPSHOT },
+			pendingTools: new Map([
+				["call-owner", owner],
+				["call-sibling", sibling],
