+	calls: [
+		{ toolCallId: "call-owner", toolName: "question", result: "missing" },
+		{ toolCallId: "call-sibling", toolName: "ordinary", result: "missing" },
+	],
+	phase: "deferred",
+	correlationId: "request-21",
+	availability: { status: "available" },
+};
+
+type PresentationContext = {
+	session: {
