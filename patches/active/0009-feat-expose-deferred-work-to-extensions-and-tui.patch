+		};
+
+		interactiveModePrototype.applyDeferredToolRows.call(context);
+
+		expect(stripAnsi(owner.render(100).join("\n"))).toContain("Package waiting");
+		expect(stripAnsi(sibling.render(100).join("\n"))).toContain("Held—not executed");
+	});
+
+	it("opens a compatible package presenter once for reconstructed waiting state", async () => {
+		const presenter = vi.fn(async () => {});
+		const context = contextFor(presenter);
+
+		await presentDeferredBatch.call(context);
+		await presentDeferredBatch.call(context);
+
+		expect(presenter).toHaveBeenCalledTimes(1);
+		expect(presenter).toHaveBeenCalledWith(SNAPSHOT, expect.any(Object));
+		expect(context.showDeferredInspector).not.toHaveBeenCalled();
+
+		context.session.deferredBatch = undefined;
+		await presentDeferredBatch.call(context);
+		context.session.deferredBatch = SNAPSHOT;
+		await presentDeferredBatch.call(context);
+		expect(presenter).toHaveBeenCalledTimes(2);
+	});
+
+	it("falls back to the generic inspector when presentation is missing or fails", async () => {
+		const missing = contextFor();
+		await presentDeferredBatch.call(missing);
+		expect(missing.showDeferredInspector).toHaveBeenCalledTimes(1);
+
+		const failure = contextFor(async () => {
+			throw new Error("presenter failed");
+		});
+		await presentDeferredBatch.call(failure);
+		expect(failure.showExtensionError).toHaveBeenCalledWith("question", "presenter failed");
+		expect(failure.showDeferredInspector).toHaveBeenCalledTimes(1);
+	});
+});
