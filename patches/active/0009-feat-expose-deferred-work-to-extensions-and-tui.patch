@@ -0,0 +1,81 @@
+import { Key, matchesKey, truncateToWidth, wrapTextWithAnsi } from "@earendil-works/pi-tui";
+import type { DeferredBatchSnapshot } from "../../../core/deferred-batch.ts";
+import { theme } from "../theme/theme.ts";
+
+export type DeferredInspectorAction = "retry" | "abandon" | "dismiss";
+
+type InspectorOption = { action: DeferredInspectorAction; label: string };
+
+export class DeferredInspectorComponent {
+	private readonly snapshot: DeferredBatchSnapshot;
+	private readonly onAction: (action: DeferredInspectorAction) => void;
+	private readonly options: InspectorOption[];
+	private selectedIndex = 0;
+
+	constructor(snapshot: DeferredBatchSnapshot, onAction: (action: DeferredInspectorAction) => void) {
+		this.snapshot = snapshot;
+		this.onAction = onAction;
+		this.options =
+			snapshot.kind === "batch"
+				? [
+						{ action: "retry", label: "Retry advancement" },
+						{ action: "abandon", label: "Abandon deferred batch" },
+						{ action: "dismiss", label: "Close" },
+					]
+				: [{ action: "dismiss", label: "Close" }];
+	}
+
+	handleInput(data: string): void {
+		if (matchesKey(data, Key.up)) {
+			this.selectedIndex = Math.max(0, this.selectedIndex - 1);
+			return;
+		}
+		if (matchesKey(data, Key.down)) {
+			this.selectedIndex = Math.min(this.options.length - 1, this.selectedIndex + 1);
+			return;
+		}
+		if (matchesKey(data, Key.enter)) {
+			this.onAction(this.options[this.selectedIndex].action);
+			return;
+		}
+		if (matchesKey(data, Key.escape)) {
+			this.onAction("dismiss");
+		}
+	}
+
+	render(width: number): string[] {
+		const renderWidth = Math.max(1, width);
+		const lines: string[] = [];
+		const add = (text: string) => lines.push(...wrapTextWithAnsi(text, renderWidth));
+
+		add(theme.fg("accent", theme.bold("Deferred tool batch")));
+		if (this.snapshot.kind === "invalid") {
+			add(theme.fg("error", `${this.snapshot.code}: ${this.snapshot.message}`));
+		} else {
+			add(theme.fg("muted", `Phase: ${this.snapshot.phase}`));
+			lines.push("");
+			for (const call of this.snapshot.calls) {
+				const owner = call.toolCallId === this.snapshot.ownerCallId ? "owner" : "held";
+				add(`  ${theme.fg("text", call.toolName)} ${theme.fg("dim", `(${owner}, ${call.result})`)}`);
+			}
+			if (this.snapshot.availability.status === "unavailable") {
+				lines.push("");
+				add(theme.fg("warning", "Unavailable:"));
+				for (const reason of this.snapshot.availability.reasons) {
+					add(`  ${theme.fg("warning", reason.message)}`);
+				}
+			}
+		}
+
+		lines.push("");
+		for (let index = 0; index < this.options.length; index++) {
+			const option = this.options[index];
+			const prefix = index === this.selectedIndex ? theme.fg("accent", "> ") : "  ";
+			add(`${prefix}${theme.fg(index === this.selectedIndex ? "accent" : "text", option.label)}`);
+		}
+		lines.push(theme.fg("dim", truncateToWidth("Up/Down to select · Enter to confirm · Esc to close", renderWidth)));
+		return lines;
+	}
+
+	invalidate(): void {}
+}
