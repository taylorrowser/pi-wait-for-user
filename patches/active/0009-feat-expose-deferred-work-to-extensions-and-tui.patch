diff --git a/packages/coding-agent/test/suite/regressions/21-extension-deferred-presentation.test.ts b/packages/coding-agent/test/suite/regressions/21-extension-deferred-presentation.test.ts
new file mode 100644
index 00000000..54581304
--- /dev/null
+++ b/packages/coding-agent/test/suite/regressions/21-extension-deferred-presentation.test.ts
@@ -0,0 +1,150 @@
+import { mkdtempSync, rmSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { join } from "node:path";
+import { fauxAssistantMessage } from "@earendil-works/pi-ai";
+import { afterEach, describe, expect, it } from "vitest";
+import { SessionManager } from "../../../src/core/session-manager.ts";
+import type {
+	DeferredBatchSnapshot,
+	DeferredOperationResult,
+	ExtensionFactory,
+	ExtensionUIContext,
+} from "../../../src/index.ts";
+import {
+	deferredToolBatchMessage,
+	type InteractionRequestTestController,
+	questionExtension,
+} from "../deferred-tool-batch-fixture.ts";
+import { createHarness, type Harness } from "../harness.ts";
+
+describe("regression #21: extension deferred presentation seam", () => {
+	const harnesses: Harness[] = [];
+	const roots: string[] = [];
+
+	afterEach(() => {
+		while (harnesses.length > 0) harnesses.pop()?.cleanup();
+		while (roots.length > 0) rmSync(roots.pop()!, { recursive: true, force: true });
+	});
+
+	it("lets an extension inspect waiting state and schedule Response resumption after its callback returns", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-extension-deferred-"));
+		roots.push(root);
+		const controller: InteractionRequestTestController = {};
+		const executions: string[] = [];
+		const callbackStates: string[] = [];
+		const snapshots: DeferredBatchSnapshot[] = [];
+		let scheduledResume: Promise<DeferredOperationResult> | undefined;
+		let scheduled = false;
+
+		const presenter: ExtensionFactory = (pi) => {
+			pi.on("agent_settled", (_event, ctx) => {
+				const snapshot = ctx.getDeferredBatch();
+				if (!snapshot || scheduled) return;
+				scheduled = true;
+				snapshots.push(snapshot);
+				controller.recordResponse?.("Ship it");
+				callbackStates.push("callback");
+				scheduledResume = pi.resumeDeferred().then((result) => {
+					callbackStates.push("resumed");
+					return result;
+				});
+				callbackStates.push("returned");
+			});
+		};
+
+		const harness = await createHarness({
+			sessionManager: SessionManager.create(root, join(root, "sessions")),
+			extensionFactories: [questionExtension(executions, controller), presenter],
+		});
+		harnesses.push(harness);
+		harness.setResponses([deferredToolBatchMessage(), fauxAssistantMessage("Continued")]);
+
+		await harness.session.prompt("Ask before shipping");
+		await scheduledResume;
+
+		expect(snapshots).toHaveLength(1);
+		expect(snapshots[0]).toMatchObject({ kind: "batch", phase: "deferred", ownerCallId: "call-1" });
+		expect(callbackStates).toEqual(["callback", "returned", "resumed"]);
+		expect(executions).toEqual(["ordinary:Prepare?", "Ship?", "ordinary:Deploy?"]);
+		expect(harness.session.deferredBatch).toBeUndefined();
+	});
+
+	it("defers advancement until a package custom UI has torn down", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-extension-custom-ui-"));
+		roots.push(root);
+		const controller: InteractionRequestTestController = {};
+		const states: string[] = [];
+		let scheduledResume: Promise<DeferredOperationResult> | undefined;
+		let scheduled = false;
+		const presenter: ExtensionFactory = (pi) => {
+			pi.on("agent_settled", async (_event, ctx) => {
+				if (!ctx.getDeferredBatch() || scheduled) return;
+				scheduled = true;
+				controller.recordResponse?.("Ship it");
+				await ctx.ui.custom<void>((_tui, _theme, _keybindings, done) => {
+					states.push("custom-callback");
+					scheduledResume = pi.resumeDeferred().then((result) => {
+						states.push("resumed");
+						return result;
+					});
+					done();
+					return { render: () => [], invalidate: () => {} };
+				});
+				states.push("custom-returned");
+			});
+		};
+		const uiContext = {
+			custom: async <T>(factory: Parameters<ExtensionUIContext["custom"]>[0]) => {
+				let result: T | undefined;
+				const component = await factory({} as never, {} as never, {} as never, (value) => {
+					result = value as T;
+				});
+				component.dispose?.();
+				states.push("custom-torn-down");
+				return result as T;
+			},
+		} as ExtensionUIContext;
+		const harness = await createHarness({
+			sessionManager: SessionManager.create(root, join(root, "sessions")),
+			extensionFactories: [questionExtension([], controller), presenter],
+		});
+		harnesses.push(harness);
+		await harness.session.bindExtensions({ mode: "tui", uiContext });
+		harness.setResponses([deferredToolBatchMessage(), fauxAssistantMessage("Continued")]);
+
+		await harness.session.prompt("Ask before shipping");
+		await scheduledResume;
+
+		expect(states).toEqual(["custom-callback", "custom-torn-down", "custom-returned", "resumed"]);
+	});
+
+	it("exposes argument-free abandonment through the same scheduled extension seam", async () => {
+		let abandonDeferred: (() => Promise<DeferredOperationResult>) | undefined;
+		const harness = await createHarness({
+			extensionFactories: [
+				(pi) => {
+					abandonDeferred = () => pi.abandonDeferred();
+				},
+			],
+		});
+		harnesses.push(harness);
+
+		await expect(abandonDeferred?.()).resolves.toEqual({ status: "none", deferredBatch: undefined });
+	});
+
+	it("rejects deferred operations captured from an extension instance invalidated by reload", async () => {
+		let oldResume: (() => Promise<DeferredOperationResult>) | undefined;
+		let loadCount = 0;
+		const extension: ExtensionFactory = (pi) => {
+			loadCount++;
+			if (loadCount === 1) oldResume = () => pi.resumeDeferred();
+		};
+		const harness = await createHarness({ extensionFactories: [extension] });
+		harnesses.push(harness);
+
+		await harness.session.bindExtensions({ mode: "tui" });
+		await harness.session.reload();
+
+		await expect(oldResume?.()).rejects.toThrow(/stale after session replacement or reload/i);
+	});
+});
