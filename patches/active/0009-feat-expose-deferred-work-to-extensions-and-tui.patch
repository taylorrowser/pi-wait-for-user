@@ -0,0 +1,65 @@
+import { beforeAll, describe, expect, it } from "vitest";
+import type { DeferredBatch } from "../src/core/deferred-batch.ts";
+import {
+	type DeferredInspectorAction,
+	DeferredInspectorComponent,
+} from "../src/modes/interactive/components/deferred-inspector.ts";
+import { initTheme } from "../src/modes/interactive/theme/theme.ts";
+import { stripAnsi } from "../src/utils/ansi.ts";
+
+const SNAPSHOT: DeferredBatch = {
+	kind: "batch",
+	sessionId: "session-21",
+	assistantEntryId: "assistant-21",
+	ownerCallId: "owner-21",
+	calls: [
+		{ toolCallId: "sibling-1", toolName: "read_policy", result: "recorded" },
+		{ toolCallId: "owner-21", toolName: "question", result: "missing" },
+		{ toolCallId: "sibling-2", toolName: "deploy", result: "missing" },
+	],
+	phase: "partial",
+	correlationId: "private-package-correlation",
+	availability: {
+		status: "unavailable",
+		reasons: [
+			{
+				code: "tool_unavailable",
+				message: "Held tool deploy is not currently active.",
+				callId: "sibling-2",
+				toolName: "deploy",
+				details: { privateArgument: "do not render" },
+			},
+		],
+	},
+};
+
+describe("DeferredInspectorComponent", () => {
+	beforeAll(() => initTheme("dark"));
+
+	it("renders neutral progress and recovery reasons without package correlation or private details", () => {
+		const component = new DeferredInspectorComponent(SNAPSHOT, () => {});
+		const rendered = stripAnsi(component.render(100).join("\n"));
+
+		expect(rendered).toContain("Deferred tool batch");
+		expect(rendered).toContain("Phase: partial");
+		expect(rendered.indexOf("read_policy")).toBeLessThan(rendered.indexOf("question"));
+		expect(rendered.indexOf("question")).toBeLessThan(rendered.indexOf("deploy"));
+		expect(rendered).toContain("recorded");
+		expect(rendered).toContain("missing");
+		expect(rendered).toContain("Held tool deploy is not currently active.");
+		expect(rendered).not.toContain("private-package-correlation");
+		expect(rendered).not.toContain("do not render");
+	});
+
+	it("offers retry, confirmed abandonment, and dismissal actions", () => {
+		const actions: DeferredInspectorAction[] = [];
+		const component = new DeferredInspectorComponent(SNAPSHOT, (action) => actions.push(action));
+
+		component.handleInput("\r");
+		component.handleInput("\x1b[B");
+		component.handleInput("\r");
+		component.handleInput("\x1b");
+
+		expect(actions).toEqual(["retry", "abandon", "dismiss"]);
+	});
+});
