+function customSurfaceFixture(onSurfaceClosed: () => void = () => {}) {
+	const dismissers = new Set<() => void>();
+	const editor = {
+		focused: false,
+		getText: () => "draft",
+		setText: vi.fn(),
+		render: () => ["EDITOR"],
+		invalidate: () => {},
+	};
+	return {
+		session: agentHarness.session,
+		activeCustomSurfaceDismissers: dismissers,
+		trackDeferredSurfaceDismisser: (dismiss: () => void) => {
+			dismissers.add(dismiss);
+			return true;
+		},
+		deferredPresentation: {
+			hasActiveSurface: () => true,
+			shouldRetireActiveSurface: () => false,
+			surfaceOpened: vi.fn(),
+			surfaceClosed: vi.fn(async () => onSurfaceClosed()),
+		},
+		editor,
+		editorContainer: new Container(),
+		keybindings: {},
+		ui: { setFocus: vi.fn(), requestRender: vi.fn(), hideOverlay: vi.fn() },
+	};
