+
+test("restores deferred affordance ownership when a custom factory throws synchronously", async () => {
+	const fakeThis = customSurfaceFixture();
+	type ShowExtensionCustom = (
+		this: typeof fakeThis,
+		factory: () => never,
+		options?: { deferredBatch?: boolean },
+	) => Promise<unknown>;
+	const showExtensionCustom = (
+		InteractiveMode as unknown as { prototype: { showExtensionCustom: ShowExtensionCustom } }
+	).prototype.showExtensionCustom;
+
+	const result = showExtensionCustom.call(
+		fakeThis,
+		() => {
+			throw new Error("factory failed");
+		},
+		{ deferredBatch: true },
+	);
+
+	await expect(result).rejects.toThrow("factory failed");
+	expect(fakeThis.deferredPresentation.surfaceOpened).toHaveBeenCalledOnce();
+	expect(fakeThis.deferredPresentation.surfaceClosed).toHaveBeenCalledOnce();
+});
+
+test("refreshes deferred presentation after the extension consumes a dismissal", async () => {
+	const order: string[] = [];
+	const fakeThis = customSurfaceFixture(() => order.push("surface closed"));
+	type ShowExtensionCustom = <T>(
+		this: typeof fakeThis,
+		factory: (tui: unknown, theme: unknown, keybindings: unknown, done: (result: T) => void) => unknown,
+		options?: { deferredBatch?: boolean },
