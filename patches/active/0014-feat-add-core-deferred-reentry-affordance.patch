diff --git a/packages/coding-agent/src/modes/interactive/deferred-presentation.ts b/packages/coding-agent/src/modes/interactive/deferred-presentation.ts
new file mode 100644
index 00000000..c02f83c2
--- /dev/null
+++ b/packages/coding-agent/src/modes/interactive/deferred-presentation.ts
@@ -0,0 +1,235 @@
+import type { DeferredBatch, DeferredBatchSnapshot } from "../../core/deferred-batch.ts";
+import type {
+	DeferredToolPresenter,
+	DeferredToolSummary,
+	DeferredToolSummaryContext,
+	ExtensionContext,
+	ToolDefinition,
+} from "../../core/extensions/types.ts";
+
+export type DeferredAffordance =
+	| { kind: "package"; text: string }
+	| { kind: "generic"; snapshot: DeferredBatchSnapshot };
+
+export interface DeferredPresentationHost {
+	getSnapshot(): DeferredBatchSnapshot | undefined;
+	getPresentationKey(snapshot: DeferredBatchSnapshot): string;
+	getToolDefinition(name: string): ToolDefinition | undefined;
+	createPresenterContext(): ExtensionContext;
+	createSummaryContext(): DeferredToolSummaryContext;
+	setAffordance(affordance: DeferredAffordance | undefined): void;
+	dismissFullSurfaces(): void;
+	showInspector(): Promise<void>;
+	showNoDeferred(): void;
+	showError(toolName: string, message: string): void;
+}
+
+export function parseDeferredCommand(text: string): "inspect" | "present" | undefined {
+	if (text === "/deferred") return "present";
+	if (text === "/deferred inspect") return "inspect";
+	return undefined;
+}
+
+type PackagePresentation = {
+	toolName: string;
+	presenter: DeferredToolPresenter;
+	summary: DeferredToolSummary | undefined;
+};
+
+/** Owns deferred presentation selection while the interactive mode supplies rendering primitives. */
+export class DeferredPresentationController {
+	private readonly host: DeferredPresentationHost;
+	private presentedKey: string | undefined;
+	private fullSurfaceDepth = 0;
+	private activeSurfaceKey: string | undefined;
+	private pendingPresentation: { force?: boolean } | undefined;
+	private failedPresenterKey: string | undefined;
+	private failedSummaryKey: string | undefined;
+	private affordanceGeneration = 0;
+
+	constructor(host: DeferredPresentationHost) {
+		this.host = host;
+	}
+
+	reset(): void {
+		this.presentedKey = undefined;
+		this.activeSurfaceKey = undefined;
+		this.pendingPresentation = undefined;
+		this.failedPresenterKey = undefined;
+		this.failedSummaryKey = undefined;
+		this.affordanceGeneration += 1;
+	}
+
+	async stateChanged(): Promise<void> {
+		const snapshot = this.host.getSnapshot();
+		if (!snapshot) {
+			this.presentedKey = undefined;
+			this.pendingPresentation = undefined;
+			if (this.activeSurfaceKey) this.host.dismissFullSurfaces();
+		} else if (this.activeSurfaceKey && this.activeSurfaceKey !== this.host.getPresentationKey(snapshot)) {
+			this.pendingPresentation = {};
+			this.host.dismissFullSurfaces();
+		}
+		await this.refreshAffordance();
+	}
+
+	async present(options: { force?: boolean } = {}): Promise<void> {
+		const snapshot = this.getActiveSnapshotOrNotify();
+		if (!snapshot) return;
+		if (this.fullSurfaceDepth > 0) {
+			this.pendingPresentation = { force: this.pendingPresentation?.force || options.force };
+			return;
+		}
+
+		const key = this.host.getPresentationKey(snapshot);
+		if (!options.force && this.presentedKey === key) {
+			await this.refreshAffordance();
+			return;
+		}
+		this.presentedKey = key;
+		this.activeSurfaceKey = key;
+
+		try {
+			await this.withFullSurface(async () => {
+				const presentation = this.getPackagePresentation(snapshot);
+				if (!presentation || this.failedPresenterKey === key) {
+					await this.host.showInspector();
+					return;
+				}
+
+				try {
+					await presentation.presenter(snapshot as DeferredBatch, this.host.createPresenterContext());
+				} catch (error) {
+					this.failedPresenterKey = key;
+					if (this.isCurrentPresentation(key)) {
+						this.host.showError(presentation.toolName, error instanceof Error ? error.message : String(error));
+						await this.host.showInspector();
+					}
+				}
+			});
+		} finally {
+			if (this.activeSurfaceKey === key) this.activeSurfaceKey = undefined;
+		}
+	}
+
+	async inspect(): Promise<void> {
+		const snapshot = this.getActiveSnapshotOrNotify();
+		if (!snapshot) return;
+		const key = this.host.getPresentationKey(snapshot);
+		this.activeSurfaceKey = key;
+		try {
+			await this.withFullSurface(() => this.host.showInspector());
+		} finally {
+			if (this.activeSurfaceKey === key) this.activeSurfaceKey = undefined;
+		}
+	}
+
+	hasActiveSurface(): boolean {
+		return this.activeSurfaceKey !== undefined;
+	}
+
+	shouldRetireActiveSurface(): boolean {
+		return this.activeSurfaceKey !== undefined && !this.isCurrentPresentation(this.activeSurfaceKey);
+	}
+
+	surfaceOpened(trackDeferredBatch = false): void {
+		if (trackDeferredBatch && !this.activeSurfaceKey) {
+			const snapshot = this.host.getSnapshot();
+			if (snapshot) this.activeSurfaceKey = this.host.getPresentationKey(snapshot);
+		}
+		this.fullSurfaceDepth += 1;
+		this.affordanceGeneration += 1;
+		this.host.setAffordance(undefined);
+	}
+
+	async surfaceClosed(): Promise<void> {
+		this.fullSurfaceDepth = Math.max(0, this.fullSurfaceDepth - 1);
+		if (this.fullSurfaceDepth === 0) {
+			this.activeSurfaceKey = undefined;
+			if (this.pendingPresentation) {
+				const pending = this.pendingPresentation;
+				this.pendingPresentation = undefined;
+				await this.present(pending);
+				return;
+			}
+		}
+		await this.refreshAffordance();
+	}
+
+	private getActiveSnapshotOrNotify(): DeferredBatchSnapshot | undefined {
+		const snapshot = this.host.getSnapshot();
+		if (snapshot) return snapshot;
+		this.presentedKey = undefined;
+		this.host.setAffordance(undefined);
+		this.host.showNoDeferred();
+		return undefined;
+	}
+
+	private async withFullSurface(open: () => Promise<void>): Promise<void> {
+		this.surfaceOpened();
+		try {
+			await open();
+		} finally {
+			await this.surfaceClosed();
+		}
+	}
+
+	private isCurrentPresentation(key: string): boolean {
+		const snapshot = this.host.getSnapshot();
+		return snapshot !== undefined && this.host.getPresentationKey(snapshot) === key;
+	}
+
+	private getPackagePresentation(snapshot: DeferredBatchSnapshot): PackagePresentation | undefined {
+		if (snapshot.kind !== "batch" || snapshot.availability.status !== "available") return undefined;
+		const owner = snapshot.calls.find((call) => call.toolCallId === snapshot.ownerCallId);
+		if (!owner) return undefined;
+		const deferral = this.host.getToolDefinition(owner.toolName)?.deferral;
+		if (!deferral?.presenter) return undefined;
+		return { toolName: owner.toolName, presenter: deferral.presenter, summary: deferral.summary };
+	}
+
+	private async refreshAffordance(): Promise<void> {
+		const generation = ++this.affordanceGeneration;
+		const snapshot = this.host.getSnapshot();
+		if (!snapshot || this.fullSurfaceDepth > 0) {
+			this.host.setAffordance(undefined);
+			return;
+		}
+
+		const key = this.host.getPresentationKey(snapshot);
+		const presentation = this.getPackagePresentation(snapshot);
+		if (!presentation?.summary || this.failedPresenterKey === key || this.failedSummaryKey === key) {
+			this.host.setAffordance({ kind: "generic", snapshot });
+			return;
+		}
+
+		this.host.setAffordance({ kind: "generic", snapshot });
+		let text: string;
+		try {
+			text = await presentation.summary(snapshot as DeferredBatch, this.host.createSummaryContext());
+		} catch (error) {
+			this.failedSummaryKey = key;
+			if (generation === this.affordanceGeneration && this.isCurrentPresentation(key)) {
+				this.host.showError(presentation.toolName, error instanceof Error ? error.message : String(error));
+				this.host.setAffordance({ kind: "generic", snapshot });
+			}
+			return;
+		}
+
+		if (
+			generation !== this.affordanceGeneration ||
+			this.fullSurfaceDepth > 0 ||
+			this.host.getSnapshot() === undefined ||
+			this.host.getPresentationKey(this.host.getSnapshot()!) !== key
+		) {
+			return;
+		}
+		if (typeof text !== "string") {
+			this.failedSummaryKey = key;
+			this.host.setAffordance({ kind: "generic", snapshot });
+			return;
+		}
+		const normalized = text.trim();
+		this.host.setAffordance(normalized ? { kind: "package", text: normalized } : { kind: "generic", snapshot });
+	}
+}
