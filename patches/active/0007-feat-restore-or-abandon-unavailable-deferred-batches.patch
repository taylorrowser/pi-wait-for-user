+import { mkdtempSync, readFileSync, rmSync, writeFileSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { join } from "node:path";
+import { fauxAssistantMessage } from "@earendil-works/pi-ai";
+import { Type } from "typebox";
+import { afterEach, describe, expect, it } from "vitest";
+import { SessionManager } from "../../../src/core/session-manager.ts";
+import {
+	deferredToolBatchMessage,
+	type InteractionRequestTestController,
+	outcomeType,
+	questionExtension,
+} from "../deferred-tool-batch-fixture.ts";
+import { createHarness, type Harness } from "../harness.ts";
+
+describe("unavailable deferred-batch recovery", () => {
+	const harnesses: Harness[] = [];
+	const roots: string[] = [];
+
+	afterEach(() => {
+		while (harnesses.length > 0) harnesses.pop()?.cleanup();
+		while (roots.length > 0) rmSync(roots.pop()!, { recursive: true, force: true });
+	});
+
+	it("advertises exact deferred protocol and operation capabilities", async () => {
+		let extensionCapabilities: unknown;
+		const harness = await createHarness({
+			extensionFactories: [
+				(pi) => {
+					pi.on("before_agent_start", (_event, ctx) => {
+						extensionCapabilities = ctx.capabilities;
+					});
+				},
+			],
+		});
+		harnesses.push(harness);
+		harness.setResponses([fauxAssistantMessage("Done")]);
+		await harness.session.prompt("Inspect capabilities");
+		const expected = {
+			deferredToolBatches: { protocolVersions: [1], operations: ["resume", "abandon"] },
+		};
+
+		expect(harness.session.capabilities).toEqual(expected);
+		expect(extensionCapabilities).toEqual(expected);
+	});
+
+	it("writes deferred work under the fail-closed downstream session identity", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-downstream-session-"));
+		roots.push(root);
+		const manager = SessionManager.create(root, join(root, "sessions"));
+		const harness = await createHarness({
+			sessionManager: manager,
+			extensionFactories: [questionExtension([])],
+		});
+		harnesses.push(harness);
+		harness.setResponses([deferredToolBatchMessage()]);
+
+		await harness.session.prompt("Ask before shipping");
+
+		const [headerLine] = readFileSync(manager.getSessionFile()!, "utf8").split("\n");
+		expect(JSON.parse(headerLine)).toMatchObject({
+			type: "dev.taylorrowser.pi-wait-for-user/session",
+			version: 1,
+			basedOnPiSessionVersion: 3,
+			id: manager.getSessionId(),
+		});
+	});
+
+	it("rejects unsupported downstream and future official session versions before mutation", () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-unsupported-session-"));
+		roots.push(root);
+		for (const [name, header] of [
+			[
+				"downstream",
+				{
+					type: "dev.taylorrowser.pi-wait-for-user/session",
+					version: 2,
+					basedOnPiSessionVersion: 3,
+					id: "unsupported-downstream",
+					timestamp: "2026-01-01T00:00:00.000Z",
+					cwd: root,
+				},
+			],
+			[
+				"official",
+				{
+					type: "session",
+					version: 999,
+					id: "unsupported-official",
+					timestamp: "2026-01-01T00:00:00.000Z",
+					cwd: root,
+				},
+			],
+		] as const) {
+			const sessionFile = join(root, `${name}.jsonl`);
+			const bytes = `${JSON.stringify(header)}\n`;
+			writeFileSync(sessionFile, bytes);
+			expect(() => SessionManager.open(sessionFile)).toThrow(/unsupported session/i);
+			expect(readFileSync(sessionFile, "utf8")).toBe(bytes);
+		}
+	});
+
+	it("keeps the whole batch unavailable when a held sibling is disabled", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-disabled-held-tool-"));
+		roots.push(root);
+		const manager = SessionManager.create(root, join(root, "sessions"));
+		const executions: string[] = [];
+		const harness = await createHarness({
+			sessionManager: manager,
+			extensionFactories: [questionExtension(executions)],
+		});
+		harnesses.push(harness);
+		harness.setResponses([deferredToolBatchMessage()]);
+		await harness.session.prompt("Ask before shipping");
+		harness.session.setActiveToolsByName(["question"]);
+		const bytesBefore = readFileSync(manager.getSessionFile()!, "utf8");
+
+		const snapshot = harness.session.deferredBatch;
+		harness.events.length = 0;
+		expect(snapshot).toMatchObject({
+			kind: "batch",
+			availability: {
+				status: "unavailable",
+				reasons: [
+					{ code: "tool_unavailable", callId: "call-0", toolName: "ordinary" },
+					{ code: "tool_unavailable", callId: "call-2", toolName: "ordinary" },
+				],
+			},
+		});
+		expect(await harness.session.resumeDeferred()).toEqual({ status: "unavailable", deferredBatch: snapshot });
+		expect(harness.events.map((event) => event.type)).toEqual(["agent_start", "agent_end", "agent_settled"]);
+		expect(executions).toEqual([]);
+		expect(harness.getPendingResponseCount()).toBe(0);
+		expect(readFileSync(manager.getSessionFile()!, "utf8")).toBe(bytesBefore);
+
+		harness.session.setActiveToolsByName(["ordinary", "question"]);
+		expect(harness.session.deferredBatch).toMatchObject({ availability: { status: "available" } });
+		expect(readFileSync(manager.getSessionFile()!, "utf8")).toBe(bytesBefore);
+	});
+
+	it("reclassifies package-schema availability after compatible code is restored", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-package-schema-recovery-"));
+		roots.push(root);
+		const manager = SessionManager.create(root, join(root, "sessions"));
+		const initial = await createHarness({
+			sessionManager: manager,
+			extensionFactories: [questionExtension([])],
+		});
+		harnesses.push(initial);
+		initial.setResponses([deferredToolBatchMessage()]);
+		await initial.session.prompt("Ask before shipping");
+		const sessionFile = manager.getSessionFile()!;
+		const bytesBefore = readFileSync(sessionFile, "utf8");
+		initial.cleanup();
+		harnesses.pop();
+
+		const incompatible = await createHarness({
+			sessionManager: SessionManager.open(sessionFile),
+			extensionFactories: [questionExtension([], undefined, { supportedPackageVersions: [2] })],
+		});
+		harnesses.push(incompatible);
+		expect(incompatible.session.deferredBatch).toMatchObject({
+			kind: "batch",
+			availability: {
+				status: "unavailable",
+				reasons: [
+					{
+						code: "package_incompatible",
+						details: { requiredPackageVersion: 1, supportedPackageVersions: [2] },
+					},
+				],
+			},
+		});
+		expect(readFileSync(sessionFile, "utf8")).toBe(bytesBefore);
+		incompatible.cleanup();
+		harnesses.pop();
+
+		const restored = await createHarness({
+			sessionManager: SessionManager.open(sessionFile),
+			extensionFactories: [questionExtension([], undefined, { supportedPackageVersions: [1] })],
+		});
+		harnesses.push(restored);
+		expect(restored.session.deferredBatch).toMatchObject({ availability: { status: "available" } });
+		expect(readFileSync(sessionFile, "utf8")).toBe(bytesBefore);
+	});
+
+	it("reports changed held-tool schemas without executing or mutating the batch", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-changed-held-schema-"));
+		roots.push(root);
+		const manager = SessionManager.create(root, join(root, "sessions"));
+		const harness = await createHarness({
+			sessionManager: manager,
+			extensionFactories: [questionExtension([])],
+		});
+		harnesses.push(harness);
+		harness.setResponses([deferredToolBatchMessage()]);
+		await harness.session.prompt("Ask before shipping");
+		const question = harness.session.agent.state.tools.find((tool) => tool.name === "question")!;
+		question.parameters = Type.Object({ question: Type.Number() });
+		const bytesBefore = readFileSync(manager.getSessionFile()!, "utf8");
+
+		const snapshot = harness.session.deferredBatch;
+		expect(snapshot).toMatchObject({
+			kind: "batch",
+			availability: {
+				status: "unavailable",
+				reasons: [{ code: "schema_incompatible", callId: "call-1", toolName: "question" }],
+			},
+		});
+		expect(await harness.session.resumeDeferred()).toEqual({ status: "unavailable", deferredBatch: snapshot });
+		expect(readFileSync(manager.getSessionFile()!, "utf8")).toBe(bytesBefore);
+	});
+
+	it("records package Cancellation before completing the owner and abandoning held siblings", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-compatible-abandonment-"));
+		roots.push(root);
+		const manager = SessionManager.create(root, join(root, "sessions"));
+		const executions: string[] = [];
+		const harness = await createHarness({
+			sessionManager: manager,
+			extensionFactories: [questionExtension(executions)],
+		});
+		harnesses.push(harness);
+		harness.setResponses([deferredToolBatchMessage()]);
+		await harness.session.prompt("Ask before shipping");
+		harness.setResponses([fauxAssistantMessage("Continued after abandonment")]);
+
+		expect(await harness.session.abandonDeferred()).toEqual({ status: "advanced", deferredBatch: undefined });
+		expect(await harness.session.abandonDeferred()).toEqual({ status: "none", deferredBatch: undefined });
+		expect(executions).toEqual(["Ship?"]);
+		const branch = manager.getBranch();
+		const cancellationIndex = branch.findIndex(
+			(entry) =>
+				entry.type === "custom" &&
+				entry.customType === outcomeType &&
+				(entry.data as { outcome?: { type?: string } }).outcome?.type === "cancellation",
+		);
+		const results = branch.flatMap((entry, index) =>
+			entry.type === "message" && entry.message.role === "toolResult" ? [{ index, message: entry.message }] : [],
+		);
+		expect(cancellationIndex).toBeGreaterThan(-1);
+		expect(results.map(({ message }) => message.toolCallId)).toEqual(["call-0", "call-1", "call-2"]);
+		expect(results.every(({ index }) => index > cancellationIndex)).toBe(true);
+		expect(results[0].message).toMatchObject({ isError: true });
+		expect(results[1].message).toMatchObject({
+			isError: false,
+			content: [{ type: "text", text: "Cancelled: abandoned" }],
+		});
+		expect(results[2].message).toMatchObject({ isError: true });
+	});
+
+	it("does not overwrite a Response that wins before abandonment", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-response-wins-abandonment-"));
+		roots.push(root);
+		const manager = SessionManager.create(root, join(root, "sessions"));
+		const executions: string[] = [];
+		const controller: InteractionRequestTestController = {};
+		const harness = await createHarness({
+			sessionManager: manager,
+			extensionFactories: [questionExtension(executions, controller)],
+		});
+		harnesses.push(harness);
+		harness.setResponses([deferredToolBatchMessage()]);
+		await harness.session.prompt("Ask before shipping");
+		expect(controller.recordResponse?.("Yes")).toMatchObject({ status: "recorded" });
+		harness.session.setActiveToolsByName(["question"]);
+		harness.setResponses([fauxAssistantMessage("Continued with the Response")]);
+
+		expect(await harness.session.abandonDeferred()).toEqual({ status: "advanced", deferredBatch: undefined });
+		expect(executions).toEqual([]);
+		const outcomes = manager
+			.getBranch()
+			.flatMap((entry) =>
+				entry.type === "custom" && entry.customType === outcomeType
+					? [(entry.data as { outcome: { type: string } }).outcome.type]
+					: [],
+			);
+		expect(outcomes).toEqual(["response"]);
+	});
+
+	it("uses core fallback without invoking package cancellation for an unsupported protocol", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-unsupported-protocol-abandonment-"));
+		roots.push(root);
+		const manager = SessionManager.create(root, join(root, "sessions"));
+		const initial = await createHarness({
+			sessionManager: manager,
+			extensionFactories: [questionExtension([])],
+		});
+		harnesses.push(initial);
+		initial.setResponses([deferredToolBatchMessage()]);
+		await initial.session.prompt("Ask before shipping");
+		const sessionFile = manager.getSessionFile()!;
+		initial.cleanup();
+		harnesses.pop();
+		const rewritten = readFileSync(sessionFile, "utf8")
+			.trimEnd()
+			.split("\n")
+			.map((line) => {
+				const entry = JSON.parse(line) as { type: string; protocolVersion?: number };
+				if (entry.type === "tool_batch_deferred") entry.protocolVersion = 99;
+				return JSON.stringify(entry);
+			})
+			.join("\n");
+		writeFileSync(sessionFile, `${rewritten}\n`);
+		const reopened = await createHarness({
+			sessionManager: SessionManager.open(sessionFile),
+			extensionFactories: [questionExtension([])],
+		});
+		harnesses.push(reopened);
+		reopened.setResponses([fauxAssistantMessage("Continued after protocol fallback")]);
+		expect(reopened.session.deferredBatch).toMatchObject({
+			availability: {
+				status: "unavailable",
+				reasons: [
+					{
+						code: "unsupported_protocol",
