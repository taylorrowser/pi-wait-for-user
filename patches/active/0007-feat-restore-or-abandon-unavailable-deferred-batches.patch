+			}
+			if (!isPersisted) {
+				if (!capability) throw new Error(`Deferred owner call ${deferred.ownerCallId} is unavailable`);
+				await emit({
+					type: "tool_batch_deferred",
+					ownerCallId: deferred.ownerCallId,
+					heldCallIds: [...deferred.heldCallIds],
+					correlationId: resolution.correlationId,
+					protocolVersion: TOOL_DEFERRAL_PROTOCOL_VERSION,
+					handlerId: capability.handlerId,
+					handlerVersion: capability.handlerVersion,
+				});
+			}
