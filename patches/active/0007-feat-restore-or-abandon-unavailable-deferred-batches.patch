diff --git a/packages/agent/src/agent-loop.ts b/packages/agent/src/agent-loop.ts
index 74cd6f0c..12751b5f 100644
--- a/packages/agent/src/agent-loop.ts
+++ b/packages/agent/src/agent-loop.ts
@@ -197,66 +197,103 @@ export async function runAgentLoopResume(
 		: undefined;
 	const capability = ownerTool?.deferral;
 	const isPersisted = deferred.correlationId !== undefined;
-	if (
-		!ownerCall ||
-		!ownerTool ||
-		!capability ||
-		(isPersisted &&
-			(capability.handlerId !== deferred.handlerId ||
-				!capability.resumableHandlerVersions.includes(deferred.handlerVersion)))
-	) {
+	const compatibleOwner =
+		ownerCall !== undefined &&
+		ownerTool !== undefined &&
+		capability !== undefined &&
+		(!isPersisted ||
+			(deferred.protocolVersion === TOOL_DEFERRAL_PROTOCOL_VERSION &&
+				capability.handlerId === deferred.handlerId &&
+				capability.resumableHandlerVersions.includes(deferred.handlerVersion)));
+	if (!compatibleOwner && !deferred.abandonment) {
 		throw new Error(`Deferred owner call ${deferred.ownerCallId} is unavailable`);
 	}
 
-	const ownerPreparation = prevalidateToolCall(currentContext, ownerCall);
+	let ownerPreparation: PreparedToolCall | undefined;
+	if (compatibleOwner) {
+		try {
+			ownerPreparation = prevalidateToolCall(currentContext, ownerCall);
+		} catch (error) {
+			if (!deferred.abandonment) throw error;
+		}
+	}
 
 	await emit({ type: "agent_start" });
-	const resolution = await invokeToolDeferralResolver(
-		capability,
-		deferred.interruption
-			? {
-					operation: "interrupt",
-					provenance: deferred.interruption.provenance,
-					toolCallId: ownerCall.id,
-					params: ownerPreparation.args,
-					persistedHandlerVersion: deferred.handlerVersion,
-				}
-			: {
-					operation: "evaluate",
-					toolCallId: ownerCall.id,
-					params: ownerPreparation.args,
-					persistedHandlerVersion: isPersisted ? deferred.handlerVersion : undefined,
-				},
-		signal,
-	);
-	if (resolution.status === "deferred") {
-		if (isPersisted && resolution.correlationId !== deferred.correlationId) {
-			throw new ToolDeferralResolverError(
-				`Deferred owner call ${deferred.ownerCallId} returned a conflicting correlation`,
+	let resolution: ToolDeferralResolution | undefined;
+	if (capability && ownerCall && ownerPreparation) {
+		try {
+			resolution = await invokeToolDeferralResolver(
+				capability,
+				deferred.abandonment
+					? {
+							operation: "cancel",
+							reason: deferred.abandonment.reason,
+							toolCallId: ownerCall.id,
+							params: ownerPreparation.args,
+							persistedHandlerVersion: isPersisted ? deferred.handlerVersion : undefined,
+						}
+					: deferred.interruption
+						? {
+								operation: "interrupt",
+								provenance: deferred.interruption.provenance,
+								toolCallId: ownerCall.id,
+								params: ownerPreparation.args,
+								persistedHandlerVersion: deferred.handlerVersion,
+							}
+						: {
+								operation: "evaluate",
+								toolCallId: ownerCall.id,
+								params: ownerPreparation.args,
+								persistedHandlerVersion: isPersisted ? deferred.handlerVersion : undefined,
+							},
+				signal,
 			);
+		} catch (error) {
+			if (!deferred.abandonment) throw error;
 		}
-		if (!isPersisted) {
-			await emit({
-				type: "tool_batch_deferred",
-				ownerCallId: deferred.ownerCallId,
-				heldCallIds: [...deferred.heldCallIds],
-				correlationId: resolution.correlationId,
-				protocolVersion: TOOL_DEFERRAL_PROTOCOL_VERSION,
-				handlerId: capability.handlerId,
-				handlerVersion: capability.handlerVersion,
-			});
+	}
+	if (resolution?.status === "deferred") {
+		if (deferred.abandonment) {
+			resolution = undefined;
+		} else {
+			if (isPersisted && resolution.correlationId !== deferred.correlationId) {
+				throw new ToolDeferralResolverError(
+					`Deferred owner call ${deferred.ownerCallId} returned a conflicting correlation`,
