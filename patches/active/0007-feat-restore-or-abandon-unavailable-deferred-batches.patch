+			return "still_deferred";
 		}
-		await emit({ type: "agent_end", messages: newMessages });
-		return "still_deferred";
 	}
-	if (resolution.status === "unavailable") throw new Error(resolution.reason);
+	if (resolution?.status === "unavailable") {
