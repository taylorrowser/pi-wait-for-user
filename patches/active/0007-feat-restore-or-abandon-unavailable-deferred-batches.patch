 			currentContext,
 			assistantMessage,
@@ -266,23 +303,35 @@ export async function runAgentLoopResume(
 			config,
 			signal,
 			emit,
+			deferred.abandonment ? "abandoned" : "interrupted",
 		);
 	} else {
-		const preparations = missingToolCalls.map((toolCall) => prevalidateToolCall(currentContext, toolCall));
-		// Recovery advances one durable append boundary at a time. A persisted
-		// result must settle before a later call may begin, regardless of the
-		// ordinary live-batch execution mode.
-		const batchExecution = await executeToolCallsSequential(
-			currentContext,
-			assistantMessage,
-			missingToolCalls,
-			config,
-			signal,
-			emit,
-			preparations,
-		);
-		if (batchExecution.status !== "completed") throw new Error("Deferred tool batch unexpectedly deferred again");
-		executed = batchExecution;
+		let preparations: PreparedToolCall[] | undefined;
+		try {
+			preparations = missingToolCalls.map((toolCall) => prevalidateToolCall(currentContext, toolCall));
+		} catch (error) {
+			if (!deferred.abandonment) throw error;
+		}
+		if (!preparations) {
+			executed = await completeAbandonedToolBatchFallback(missingToolCalls, emit);
+		} else {
+			// Recovery advances one durable append boundary at a time. A persisted
+			// result must settle before a later call may begin, regardless of the
+			// ordinary live-batch execution mode.
+			const batchExecution = await executeToolCallsSequential(
+				currentContext,
+				assistantMessage,
+				missingToolCalls,
+				config,
+				signal,
+				emit,
+				preparations,
+			);
+			if (batchExecution.status !== "completed") {
+				throw new Error("Deferred tool batch unexpectedly deferred again");
+			}
+			executed = batchExecution;
+		}
 	}
 	for (const result of executed.messages) {
 		currentContext.messages.push(result);
@@ -921,6 +970,7 @@ async function completeInterruptedToolBatch(
 	config: AgentLoopConfig,
 	signal: AbortSignal | undefined,
 	emit: AgentEventSink,
+	disposition: "interrupted" | "abandoned" = "interrupted",
 ): Promise<Extract<ExecutedToolCallBatch, { status: "completed" }>> {
 	const messages: ToolResultMessage[] = [];
 	for (const toolCall of missingToolCalls) {
@@ -958,7 +1008,7 @@ async function completeInterruptedToolBatch(
 			finalized = {
 				toolCall,
 				result: createErrorToolResult(
-					`Tool call "${toolCall.name}" was not executed because the deferred interaction was interrupted.`,
+					`Tool call "${toolCall.name}" was not executed because the deferred interaction was ${disposition}.`,
 				),
 				isError: true,
 			};
@@ -970,6 +1020,26 @@ async function completeInterruptedToolBatch(
 	return { status: "completed", messages, terminate: false };
 }
 
+async function completeAbandonedToolBatchFallback(
+	missingToolCalls: AgentToolCall[],
+	emit: AgentEventSink,
+): Promise<Extract<ExecutedToolCallBatch, { status: "completed" }>> {
+	const messages: ToolResultMessage[] = [];
+	for (const toolCall of missingToolCalls) {
+		const finalized: FinalizedToolCallOutcome = {
+			toolCall,
+			result: createErrorToolResult(
+				`Tool call "${toolCall.name}" was not executed because the deferred interaction was abandoned while compatible package code was unavailable.`,
+			),
+			isError: true,
+		};
+		const message = createToolResultMessage(finalized);
+		await emitToolResultMessage(message, emit);
+		messages.push(message);
+	}
+	return { status: "completed", messages, terminate: false };
+}
+
 async function executeToolCallsSequential(
 	currentContext: AgentContext,
 	assistantMessage: AssistantMessage,
