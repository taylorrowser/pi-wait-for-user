diff --git a/packages/coding-agent/test/suite/agent-session-deferred.test.ts b/packages/coding-agent/test/suite/agent-session-deferred.test.ts
new file mode 100644
index 00000000..6ab43a66
--- /dev/null
+++ b/packages/coding-agent/test/suite/agent-session-deferred.test.ts
@@ -0,0 +1,192 @@
+import { mkdtempSync, readFileSync, rmSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { join } from "node:path";
+import { fauxAssistantMessage, fauxToolCall } from "@earendil-works/pi-ai";
+import { Type } from "typebox";
+import { afterEach, describe, expect, it } from "vitest";
+import type { ExtensionFactory } from "../../src/core/extensions/index.ts";
+import { type SessionEntry, SessionManager } from "../../src/core/session-manager.ts";
+import { createHarness, type Harness } from "./harness.ts";
+
+const requestType = "dev.example.question/request";
+
+function questionExtension(executions: string[]): ExtensionFactory {
+	return (pi) => {
+		pi.registerTool({
+			name: "question",
+			label: "Question",
+			description: "Wait for an answer",
+			parameters: Type.Object({ question: Type.String() }),
+			deferral: {
+				handlerId: "dev.example.question",
+				handlerVersion: 1,
+				resumableHandlerVersions: [1],
+				resolve: async (request, _signal, ctx) => {
+					const branch = ctx.sessionManager.getBranch();
+					let assistantEntry: SessionEntry | undefined;
+					for (let index = branch.length - 1; index >= 0; index--) {
+						const entry = branch[index];
+						if (
+							entry.type === "message" &&
+							entry.message.role === "assistant" &&
+							entry.message.content.some(
+								(content) => content.type === "toolCall" && content.id === request.toolCallId,
+							)
+						) {
+							assistantEntry = entry;
+							break;
+						}
+					}
+					if (!assistantEntry) throw new Error("owning assistant entry not found");
+					pi.appendEntry(requestType, {
+						version: 1,
+						requestId: "request-1",
+						assistantEntryId: assistantEntry.id,
+						ownerCallId: request.toolCallId,
+						payload: { question: request.params.question },
+					});
+					return { status: "deferred", correlationId: "request-1" };
+				},
+			},
+			async execute(_toolCallId, params) {
+				executions.push(params.question);
+				return { content: [{ type: "text", text: params.question }], details: {} };
+			},
+		});
+	};
+}
+
+describe("durable single-tool deferral", () => {
+	const harnesses: Harness[] = [];
+	const roots: string[] = [];
+
+	afterEach(() => {
+		while (harnesses.length > 0) harnesses.pop()?.cleanup();
+		while (roots.length > 0) rmSync(roots.pop()!, { recursive: true, force: true });
+	});
+
+	it("persists request before marker and reconstructs the same settled snapshot after reopen", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-deferred-session-"));
+		roots.push(root);
+		const sessionManager = SessionManager.create(root, join(root, "sessions"));
+		const executions: string[] = [];
+		const extension = questionExtension(executions);
+		const harness = await createHarness({ sessionManager, extensionFactories: [extension] });
+		harnesses.push(harness);
+		harness.setResponses([
+			fauxAssistantMessage(fauxToolCall("question", { question: "Ship?" }, { id: "call-1" }), {
+				stopReason: "toolUse",
+			}),
+		]);
+
+		await harness.session.prompt("Ask before shipping");
+
+		expect(executions).toEqual([]);
+		expect(harness.getPendingResponseCount()).toBe(0);
+		expect(harness.events.some((event) => event.type === "tool_execution_start")).toBe(false);
+		expect(harness.events.some((event) => event.type === "turn_end")).toBe(false);
+		expect(harness.events.some((event) => event.type === "agent_settled")).toBe(true);
+		expect(harness.session.isStreaming).toBe(false);
+		expect(harness.session.isIdle).toBe(true);
+		const entries = sessionManager.getBranch();
+		const assistantEntry = entries.find((entry) => entry.type === "message" && entry.message.role === "assistant");
+		const requestEntry = entries.find((entry) => entry.type === "custom" && entry.customType === requestType);
+		const markerEntry = entries.find((entry) => entry.type === "tool_batch_deferred");
+		expect(assistantEntry).toBeDefined();
+		expect(requestEntry?.parentId).toBe(assistantEntry?.id);
+		expect(sessionManager.buildSessionContext().messages.map((message) => message.role)).toEqual([
+			"user",
+			"assistant",
+		]);
+		expect(markerEntry).toMatchObject({
+			type: "tool_batch_deferred",
+			parentId: requestEntry?.id,
+			assistantEntryId: assistantEntry?.id,
+			ownerCallId: "call-1",
+			heldCallIds: ["call-1"],
+			correlationId: "request-1",
+			protocolVersion: 1,
+			handlerId: "dev.example.question",
+			handlerVersion: 1,
+		});
+		const expectedSnapshot = {
+			kind: "batch",
+			sessionId: sessionManager.getSessionId(),
+			assistantEntryId: assistantEntry?.id,
+			ownerCallId: "call-1",
+			calls: [{ toolCallId: "call-1", toolName: "question", result: "missing" }],
+			phase: "deferred",
+			correlationId: "request-1",
+			availability: { status: "available" },
+		};
+		expect(harness.session.deferredBatch).toEqual(expectedSnapshot);
+
+		const sessionFile = sessionManager.getSessionFile();
