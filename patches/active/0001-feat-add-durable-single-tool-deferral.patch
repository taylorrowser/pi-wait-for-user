+export const TOOL_DEFERRAL_PROTOCOL_VERSION = 1;
+
+/** Initial operation passed to a tool-owned deferral resolver. */
+export interface EvaluateToolDeferralRequest<TParams = unknown> {
+	operation: "evaluate";
+	toolCallId: string;
+	params: TParams;
+	persistedHandlerVersion: undefined;
+}
+
+/** Result of evaluating whether a tool call should execute or defer durably. */
+export type ToolDeferralResolution =
+	| { status: "ready" }
+	| { status: "deferred"; correlationId: string }
+	| { status: "unavailable"; reason: string };
+
+/** Versioned capability owned by the tool that may durably defer its call. */
+export interface AgentToolDeferral<TParams = unknown> {
+	handlerId: string;
+	handlerVersion: number;
+	resumableHandlerVersions: readonly number[];
+	resolve(request: EvaluateToolDeferralRequest<TParams>, signal?: AbortSignal): Promise<ToolDeferralResolution>;
+}
+
 /** Context passed to `beforeToolCall`. */
 export interface BeforeToolCallContext {
 	/** The assistant message that requested the tool call. */
