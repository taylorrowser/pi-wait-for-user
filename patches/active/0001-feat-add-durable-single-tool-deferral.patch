new file mode 100644
index 00000000..4ae4ac6e
--- /dev/null
+++ b/packages/coding-agent/src/core/deferred-batch.ts
@@ -0,0 +1,95 @@
+import { type AgentTool, TOOL_DEFERRAL_PROTOCOL_VERSION } from "@earendil-works/pi-agent-core";
+import type { AssistantMessage } from "@earendil-works/pi-ai";
+import type { SessionEntry, SessionManager, ToolBatchDeferredEntry } from "./session-manager.ts";
+
+export interface DeferredBatchCallSnapshot {
+	toolCallId: string;
+	toolName: string;
+	result: "missing" | "recorded";
+}
+
+export interface DeferredBatchSnapshot {
+	kind: "batch";
+	sessionId: string;
+	assistantEntryId: string;
+	ownerCallId: string;
+	calls: DeferredBatchCallSnapshot[];
+	phase: "markerless" | "deferred";
+	correlationId?: string;
+	availability: { status: "available" };
+}
+
+type AssistantBatch = {
+	entryId: string;
+	calls: Extract<AssistantMessage["content"][number], { type: "toolCall" }>[];
+};
+
+function recordedResultIds(branch: SessionEntry[]): Set<string> {
+	return new Set(
+		branch.flatMap((entry) =>
+			entry.type === "message" && entry.message.role === "toolResult" ? [entry.message.toolCallId] : [],
+		),
+	);
+}
+
+function findLatestUnmatchedBatch(branch: SessionEntry[], resultIds: ReadonlySet<string>): AssistantBatch | undefined {
+	for (let index = branch.length - 1; index >= 0; index--) {
+		const entry = branch[index];
+		if (entry.type !== "message" || entry.message.role !== "assistant") continue;
+		const calls = entry.message.content.filter((content) => content.type === "toolCall");
+		if (calls.some((call) => !resultIds.has(call.id))) return { entryId: entry.id, calls };
+	}
+	return undefined;
+}
+
+function findMarker(branch: SessionEntry[], assistantEntryId: string): ToolBatchDeferredEntry | undefined {
+	for (let index = branch.length - 1; index >= 0; index--) {
+		const entry = branch[index];
+		if (entry.type === "tool_batch_deferred" && entry.assistantEntryId === assistantEntryId) return entry;
+	}
+	return undefined;
+}
+
+export function reconstructDeferredBatch(
+	sessionManager: SessionManager,
+	tools: readonly AgentTool[],
+): DeferredBatchSnapshot | undefined {
+	const branch = sessionManager.getBranch();
+	const resultIds = recordedResultIds(branch);
+	const batch = findLatestUnmatchedBatch(branch, resultIds);
+	if (!batch) return undefined;
+	const marker = findMarker(branch, batch.entryId);
+	let ownerCallId: string;
+	if (marker) {
+		const ownerCall = batch.calls.find((call) => call.id === marker.ownerCallId);
+		const owner = ownerCall ? tools.find((tool) => tool.name === ownerCall.name) : undefined;
+		if (
+			!owner?.deferral ||
+			marker.protocolVersion !== TOOL_DEFERRAL_PROTOCOL_VERSION ||
+			owner.deferral.handlerId !== marker.handlerId ||
+			!owner.deferral.resumableHandlerVersions.includes(marker.handlerVersion)
+		) {
+			return undefined;
+		}
+		ownerCallId = marker.ownerCallId;
+	} else {
+		const owners = batch.calls.filter((call) => tools.some((tool) => tool.name === call.name && tool.deferral));
+		if (owners.length !== 1) return undefined;
+		ownerCallId = owners[0].id;
+	}
+
+	return {
+		kind: "batch",
+		sessionId: sessionManager.getSessionId(),
+		assistantEntryId: batch.entryId,
+		ownerCallId,
+		calls: batch.calls.map((call) => ({
+			toolCallId: call.id,
+			toolName: call.name,
+			result: resultIds.has(call.id) ? "recorded" : "missing",
+		})),
+		phase: marker ? "deferred" : "markerless",
+		...(marker ? { correlationId: marker.correlationId } : {}),
+		availability: { status: "available" },
+	};
+}
