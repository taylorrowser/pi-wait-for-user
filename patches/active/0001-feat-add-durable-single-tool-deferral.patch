-};
+type ExecutedToolCallBatch =
+	| {
+			status: "completed";
+			messages: ToolResultMessage[];
+			terminate: boolean;
+	  }
+	| {
+			status: "deferred";
+			ownerCallId: string;
+			heldCallIds: string[];
+			correlationId: string;
+			handlerId: string;
+			handlerVersion: number;
+	  };
+
+async function resolveSingleToolDeferral(
+	currentContext: AgentContext,
+	toolCalls: AgentToolCall[],
+	config: AgentLoopConfig,
+	signal: AbortSignal | undefined,
+	emit: AgentEventSink,
+): Promise<
+	| Extract<ExecutedToolCallBatch, { status: "deferred" | "completed" }>
+	| { status: "ready"; preparation: PreparedToolCall }
+	| undefined
+> {
+	const owners = toolCalls.flatMap((toolCall) => {
+		const tool = currentContext.tools?.find((candidate) => candidate.name === toolCall.name);
+		return tool?.deferral ? [{ toolCall, tool, deferral: tool.deferral }] : [];
+	});
+	if (owners.length === 0) return undefined;
+	if (toolCalls.length !== 1 || owners.length !== 1) {
+		return failToolBatchBeforeDeferral(
+			toolCalls,
+			"Tool call was not executed: durable tool deferral currently requires a single-call batch.",
+			emit,
+		);
+	}
+	const { toolCall, tool, deferral } = owners[0];
+	if (!config.toolDeferralEnabled) {
+		return failToolBatchBeforeDeferral(
+			toolCalls,
+			"Tool call was not executed: durable tool deferral requires a persistent host session.",
+			emit,
+		);
+	}
+
+	let preparation: PreparedToolCall;
+	try {
+		const preparedToolCall = prepareToolCallArguments(tool, toolCall);
+		preparation = {
+			kind: "prepared",
+			toolCall,
+			tool,
+			args: validateToolArguments(tool, preparedToolCall),
+		};
+	} catch (error) {
+		return failToolBatchBeforeDeferral(toolCalls, error instanceof Error ? error.message : String(error), emit);
+	}
+	const resolution = await deferral.resolve(
+		{
+			operation: "evaluate",
+			toolCallId: toolCall.id,
+			params: preparation.args,
+			persistedHandlerVersion: undefined,
+		},
+		signal,
+	);
+	if (resolution.status === "ready") {
+		return { status: "ready", preparation };
+	}
+	if (resolution.status === "unavailable") {
+		throw new Error(resolution.reason);
+	}
+	return {
+		status: "deferred",
+		ownerCallId: toolCall.id,
+		heldCallIds: [toolCall.id],
+		correlationId: resolution.correlationId,
+		handlerId: deferral.handlerId,
+		handlerVersion: deferral.handlerVersion,
+	};
+}
+
+async function failToolBatchBeforeDeferral(
+	toolCalls: AgentToolCall[],
+	reason: string,
+	emit: AgentEventSink,
+): Promise<Extract<ExecutedToolCallBatch, { status: "completed" }>> {
+	const messages: ToolResultMessage[] = [];
+	for (const toolCall of toolCalls) {
+		await emit({
+			type: "tool_execution_start",
+			toolCallId: toolCall.id,
+			toolName: toolCall.name,
+			args: toolCall.arguments,
+		});
+		const finalized: FinalizedToolCallOutcome = {
+			toolCall,
+			result: createErrorToolResult(reason),
+			isError: true,
+		};
+		await emitToolExecutionEnd(finalized, emit);
+		const message = createToolResultMessage(finalized);
+		await emitToolResultMessage(message, emit);
+		messages.push(message);
+	}
+	return { status: "completed", messages, terminate: false };
+}
 
