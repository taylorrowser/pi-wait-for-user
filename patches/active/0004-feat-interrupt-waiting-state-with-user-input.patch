+		roots.push(root);
+		const manager = SessionManager.create(root, join(root, "sessions"));
+		const executions: string[] = [];
+		const harness = await createHarness({
+			sessionManager: manager,
+			extensionFactories: [
+				questionExtension(executions, undefined, {
+					beforeInitialDeferral: async () => {
+						resolverStarted();
+						await resolverRelease;
+					},
+				}),
+			],
+		});
+		harnesses.push(harness);
+		harness.setResponses([deferredToolBatchMessage(), fauxAssistantMessage("Continued once")]);
+
+		const promptPromise = harness.session.prompt("Ask before shipping");
+		await waitForResolver;
+		await harness.session.steer("steer one");
+		await harness.session.steer("steer two");
+		await harness.session.followUp("follow up one");
