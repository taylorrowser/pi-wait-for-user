+async function interruptToolBatchBeforeMarker(
+	deferred: Extract<ExecutedToolCallBatch, { status: "deferred" }>,
+	currentContext: AgentContext,
+	assistantMessage: AssistantMessage,
+	config: AgentLoopConfig,
+	signal: AbortSignal | undefined,
+	emit: AgentEventSink,
+): Promise<Extract<ExecutedToolCallBatch, { status: "completed" }>> {
+	const resolution = await invokeToolDeferralResolver(
+		deferred.capability,
+		{
+			operation: "interrupt",
+			provenance: "preexisting_user_input",
+			toolCallId: deferred.ownerCall.id,
+			params: deferred.ownerPreparation.args,
+			persistedHandlerVersion: undefined,
+		},
+		signal,
+	);
+	if (resolution.status === "unavailable") throw new Error(resolution.reason);
+	if (resolution.status !== "ready" || resolution.disposition !== "complete_owner") {
+		throw new ToolDeferralResolverError(
+			`Deferred owner call ${deferred.ownerCallId} did not accept preexisting user input`,
+		);
+	}
+	return completeInterruptedToolBatch(
+		currentContext,
+		assistantMessage,
+		assistantMessage.content.filter((content) => content.type === "toolCall"),
+		deferred.ownerCall,
+		deferred.ownerPreparation,
+		config,
+		signal,
+		emit,
+	);
+}
+
+async function completeInterruptedToolBatch(
+	currentContext: AgentContext,
+	assistantMessage: AssistantMessage,
+	missingToolCalls: AgentToolCall[],
+	ownerCall: AgentToolCall,
+	ownerPreparation: PreparedToolCall,
+	config: AgentLoopConfig,
+	signal: AbortSignal | undefined,
+	emit: AgentEventSink,
+): Promise<Extract<ExecutedToolCallBatch, { status: "completed" }>> {
+	const messages: ToolResultMessage[] = [];
+	for (const toolCall of missingToolCalls) {
+		let finalized: FinalizedToolCallOutcome;
+		if (toolCall.id === ownerCall.id) {
+			await emit({
+				type: "tool_execution_start",
+				toolCallId: toolCall.id,
+				toolName: toolCall.name,
+				args: toolCall.arguments,
+			});
+			const preparation = await prepareToolCall(
+				currentContext,
+				assistantMessage,
+				toolCall,
+				config,
+				signal,
+				ownerPreparation,
+			);
+			if (preparation.kind === "immediate") {
+				finalized = { toolCall, result: preparation.result, isError: preparation.isError };
+			} else {
+				const executed = await executePreparedToolCall(preparation, signal, emit);
+				finalized = await finalizeExecutedToolCall(
+					currentContext,
+					assistantMessage,
+					preparation,
+					executed,
+					config,
+					signal,
+				);
+			}
+			await emitToolExecutionEnd(finalized, emit);
+		} else {
+			finalized = {
+				toolCall,
+				result: createErrorToolResult(
+					`Tool call "${toolCall.name}" was not executed because the deferred interaction was interrupted.`,
+				),
+				isError: true,
+			};
+		}
+		messages.push(createToolResultMessage(finalized));
+	}
+	for (const message of messages) await emitToolResultMessage(message, emit);
+	return { status: "completed", messages, terminate: false };
+}
