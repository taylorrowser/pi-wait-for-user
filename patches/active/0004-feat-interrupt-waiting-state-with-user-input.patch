+			{ steering: ["steer one"], followUp: [] },
+			{ steering: ["steer one", "steer two"], followUp: [] },
+			{ steering: ["steer one", "steer two"], followUp: ["follow up one"] },
+			{ steering: ["steer one", "steer two"], followUp: ["follow up one", "follow up two"] },
+			{ steering: ["steer two"], followUp: ["follow up one", "follow up two"] },
+			{ steering: [], followUp: ["follow up one", "follow up two"] },
+			{ steering: [], followUp: ["follow up two"] },
+			{ steering: [], followUp: [] },
+		]);
+		expect(manager.getBranch().some((entry) => entry.type === "tool_batch_deferred")).toBe(false);
+		const interruption = manager
+			.getBranch()
+			.find((entry) => entry.type === "custom" && entry.customType === outcomeType);
+		expect(interruption?.type === "custom" ? interruption.data : undefined).toMatchObject({
+			outcome: { type: "interruption", provenance: "preexisting_user_input" },
+		});
+		expect(harness.getPendingResponseCount()).toBe(0);
+	});
+
+	it("orders a prompt after the durable marker even while the deferring run is settling", async () => {
