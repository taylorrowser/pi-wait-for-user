+		expect(executions).toEqual(["Ship?"]);
+		expect(getUserTexts(harness)).toEqual(["Ask before shipping", "Do something else"]);
+		expect(harness.session.deferredBatch).toBeUndefined();
+		expect(harness.getPendingResponseCount()).toBe(0);
+	});
+
+	it("rejects memory-only queue and turn injection APIs after durable deferral", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-reject-waiting-queues-"));
+		roots.push(root);
+		const manager = SessionManager.create(root, join(root, "sessions"));
+		const harness = await createHarness({
+			sessionManager: manager,
+			extensionFactories: [questionExtension([])],
