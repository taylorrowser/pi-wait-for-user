+import { SessionManager } from "../../../src/core/session-manager.ts";
+import { SettingsManager } from "../../../src/core/settings-manager.ts";
+import { initTheme } from "../../../src/modes/interactive/theme/theme.ts";
+
+const roots: string[] = [];
+
+afterEach(() => {
+	while (roots.length > 0) rmSync(roots.pop()!, { recursive: true, force: true });
+});
+
+async function loadWithDeferral(deferralSource: string) {
+	const root = mkdtempSync(join(tmpdir(), "pi-deferral-registration-"));
+	roots.push(root);
+	const extensionPath = join(root, "extension.ts");
+	writeFileSync(
+		extensionPath,
+		`import { Type } from "typebox";
+export default function (pi) {
+	pi.registerTool({
+		name: "wait",
+		label: "Wait",
+		description: "Wait durably",
+		parameters: Type.Object({}),
+		deferral: ${deferralSource},
+		execute: async () => ({ content: [{ type: "text", text: "done" }], details: {} }),
+	});
+}`,
+	);
+	return loadExtensions([extensionPath], root);
+}
+
+describe("deferred tool registration", () => {
+	it.each([
+		["null", "deferral must be an object"],
+		[
+			`{ handlerId: "question", handlerVersion: 1, resumableHandlerVersions: [1], resolve: async () => ({ status: "deferred", correlationId: "1" }) }`,
+			"deferral.handlerId must be a globally namespaced identifier",
+		],
+		[
+			`{ handlerId: "dev.example.wait", handlerVersion: 0, resumableHandlerVersions: [1], resolve: async () => ({ status: "deferred", correlationId: "1" }) }`,
+			"deferral.handlerVersion must be a positive integer",
+		],
+		[
+			`{ handlerId: "dev.example.wait", handlerVersion: 1, resumableHandlerVersions: [], resolve: async () => ({ status: "deferred", correlationId: "1" }) }`,
+			"deferral.resumableHandlerVersions must be a non-empty array",
+		],
+		[
+			`{ handlerId: "dev.example.wait", handlerVersion: 1, resumableHandlerVersions: [1, 1], resolve: async () => ({ status: "deferred", correlationId: "1" }) }`,
+			"deferral.resumableHandlerVersions must not contain duplicates",
+		],
+		[
+			`{ handlerId: "dev.example.wait", handlerVersion: 2, resumableHandlerVersions: [1], resolve: async () => ({ status: "deferred", correlationId: "1" }) }`,
+			"deferral.resumableHandlerVersions must include handlerVersion 2",
+		],
+		[
+			`{ handlerId: "dev.example.wait", handlerVersion: 1, resumableHandlerVersions: [0, 1], resolve: async () => ({ status: "deferred", correlationId: "1" }) }`,
+			"deferral.resumableHandlerVersions must contain only positive integers",
+		],
+		[
+			`{ handlerId: "dev.example.wait", handlerVersion: 1, resumableHandlerVersions: [1], resolve: "later" }`,
+			"deferral.resolve must be a function",
+		],
+		[
+			`{ handlerId: "dev.example.wait", handlerVersion: 1, resumableHandlerVersions: [1], inspectAvailability: true, resolve: async () => ({ status: "deferred", correlationId: "1" }) }`,
+			"deferral.inspectAvailability must be a function",
+		],
+		[
+			`{ handlerId: "dev.example.wait", handlerVersion: 1, resumableHandlerVersions: [1], presenter: {}, resolve: async () => ({ status: "deferred", correlationId: "1" }) }`,
+			"deferral.presenter must be a function",
+		],
+	])("rejects invalid capability %s", async (deferralSource, expectedMessage) => {
+		const result = await loadWithDeferral(deferralSource);
+
+		expect(result.extensions).toEqual([]);
+		expect(result.errors).toHaveLength(1);
+		expect(result.errors[0]?.error).toContain(`Tool "wait" ${expectedMessage}`);
+	});
+
+	it("rejects invalid deferred capabilities on SDK custom tools", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-sdk-deferral-registration-"));
+		roots.push(root);
+		const agentDir = join(root, "agent");
+		initTheme("dark");
+		const settingsManager = SettingsManager.create(root, agentDir);
+		const resourceLoader = new DefaultResourceLoader({
+			cwd: root,
+			agentDir,
+			settingsManager,
+		});
+		await resourceLoader.reload();
+
+		await expect(
+			createAgentSession({
+				cwd: root,
+				agentDir,
+				model: getModel("anthropic", "claude-sonnet-4-5")!,
+				settingsManager,
+				sessionManager: SessionManager.inMemory(),
+				resourceLoader,
+				customTools: [
+					{
+						name: "sdk_wait",
+						label: "SDK Wait",
+						description: "Invalid deferred SDK tool",
+						parameters: Type.Object({}),
+						deferral: {
+							handlerId: "sdk-wait",
+							handlerVersion: 1,
+							resumableHandlerVersions: [1],
+							resolve: async () => ({ status: "deferred", correlationId: "request-1" }),
+						},
+						execute: async () => ({ content: [{ type: "text", text: "ok" }], details: {} }),
+					},
+				],
+			}),
+		).rejects.toThrow(/Tool "sdk_wait" deferral\.handlerId must be a globally namespaced identifier/);
+	});
+
+	it("accepts an exact, versioned capability", async () => {
+		const result = await loadWithDeferral(`{
+			handlerId: "dev.example.wait",
+			handlerVersion: 2,
+			resumableHandlerVersions: [1, 2],
+			inspectAvailability: () => ({ status: "available" }),
+			resolve: async () => ({ status: "deferred", correlationId: "1" }),
+			presenter: async () => {},
+		}`);
+
+		expect(result.errors).toEqual([]);
+		expect(result.extensions).toHaveLength(1);
+	});
+});
