@@ -0,0 +1,47 @@
+import type { ToolDefinition } from "./types.ts";
+
+const HANDLER_ID_PATTERN = /^[a-z0-9](?:[a-z0-9_-]*[a-z0-9])?(?:\.[a-z0-9](?:[a-z0-9_-]*[a-z0-9])?)+$/;
+
+function fail(toolName: string, message: string): never {
+	throw new Error(`Tool "${toolName}" ${message}`);
+}
+
+/** Validate the runtime shape and compatibility claims of a durable deferral capability. */
+export function validateToolDeferralRegistration(tool: ToolDefinition): void {
+	const deferral = tool.deferral as unknown;
+	if (deferral === undefined) return;
+	if (deferral === null || typeof deferral !== "object" || Array.isArray(deferral)) {
+		fail(tool.name, "deferral must be an object");
+	}
+
+	const capability = deferral as Record<string, unknown>;
+	if (typeof capability.handlerId !== "string" || !HANDLER_ID_PATTERN.test(capability.handlerId)) {
+		fail(tool.name, 'deferral.handlerId must be a globally namespaced identifier such as "com.example.package.wait"');
+	}
+	if (!Number.isInteger(capability.handlerVersion) || (capability.handlerVersion as number) <= 0) {
+		fail(tool.name, "deferral.handlerVersion must be a positive integer");
+	}
+
+	const versions = capability.resumableHandlerVersions;
+	if (!Array.isArray(versions) || versions.length === 0) {
+		fail(tool.name, "deferral.resumableHandlerVersions must be a non-empty array");
+	}
+	if (!versions.every((version) => Number.isInteger(version) && version > 0)) {
+		fail(tool.name, "deferral.resumableHandlerVersions must contain only positive integers");
+	}
+	if (new Set(versions).size !== versions.length) {
+		fail(tool.name, "deferral.resumableHandlerVersions must not contain duplicates");
+	}
+	if (!versions.includes(capability.handlerVersion)) {
+		fail(tool.name, `deferral.resumableHandlerVersions must include handlerVersion ${capability.handlerVersion}`);
+	}
+	if (typeof capability.resolve !== "function") {
+		fail(tool.name, "deferral.resolve must be a function");
+	}
+	if (capability.inspectAvailability !== undefined && typeof capability.inspectAvailability !== "function") {
+		fail(tool.name, "deferral.inspectAvailability must be a function when provided");
+	}
+	if (capability.presenter !== undefined && typeof capability.presenter !== "function") {
+		fail(tool.name, "deferral.presenter must be a function when provided");
+	}
+}
