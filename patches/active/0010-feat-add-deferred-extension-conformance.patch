new file mode 100644
index 00000000..9d2cf204
--- /dev/null
+++ b/packages/coding-agent/examples/extensions/durable-deferral.ts
@@ -0,0 +1,209 @@
+import type { ExtensionAPI, ExtensionFactory, SessionEntry } from "@earendil-works/pi-coding-agent";
+import { Text } from "@earendil-works/pi-tui";
+import { Type } from "typebox";
+
+const REQUEST_TYPE = "dev.pi.example.durable-wait/request";
+const OUTCOME_TYPE = "dev.pi.example.durable-wait/outcome";
+const PACKAGE_VERSION = 1;
+export const RESPONSE_EVENT = "dev.pi.example.durable-wait/respond";
+export const CANCELLATION_EVENT = "dev.pi.example.durable-wait/cancel";
+export const OUTCOME_RECORDED_EVENT = "dev.pi.example.durable-wait/outcome-recorded";
+
+interface WaitRequest {
+	version: typeof PACKAGE_VERSION;
+	requestId: string;
+	assistantEntryId: string;
+	ownerCallId: string;
+	payload: { prompt: string };
+}
+
+export interface WaitOutcome {
+	version: typeof PACKAGE_VERSION;
+	requestId: string;
+	outcome:
+		| { type: "response"; value: string }
+		| { type: "interruption"; provenance: "new_user_prompt" | "preexisting_user_input" }
+		| { type: "cancellation"; reason: string };
+}
+
+export type RecordWaitOutcomeResult =
+	| { status: "recorded"; outcome: WaitOutcome }
+	| { status: "conflict"; outcome: WaitOutcome };
+
+/** Package-specific outcome seam used by SDK/RPC hosts and the conformance command. */
+export interface DurableWaitController {
+	respond(value: string): RecordWaitOutcomeResult;
+	cancel(reason: string): RecordWaitOutcomeResult;
+	getOutcome(): WaitOutcome | undefined;
+}
+
+function customData<T>(entry: SessionEntry, customType: string): T | undefined {
+	return entry.type === "custom" && entry.customType === customType ? (entry.data as T) : undefined;
+}
+
+function findLast<T>(branch: SessionEntry[], customType: string): T | undefined {
+	for (let index = branch.length - 1; index >= 0; index--) {
+		const data = customData<T>(branch[index], customType);
+		if (data) return data;
+	}
+	return undefined;
+}
+
+function findOwningAssistant(branch: SessionEntry[], toolCallId: string): Extract<SessionEntry, { type: "message" }> {
+	for (let index = branch.length - 1; index >= 0; index--) {
+		const entry = branch[index];
+		if (
+			entry.type === "message" &&
+			entry.message.role === "assistant" &&
+			entry.message.content.some((content) => content.type === "toolCall" && content.id === toolCallId)
+		) {
+			return entry;
+		}
+	}
+	throw new Error(`Owning assistant entry for ${toolCallId} was not found`);
+}
+
+export function createDurableWaitExtension(controller?: Partial<DurableWaitController>): ExtensionFactory {
+	return (pi: ExtensionAPI) => {
+		let currentBranch: (() => SessionEntry[]) | undefined;
+
+		const getRequest = (): WaitRequest => {
+			const request = currentBranch && findLast<WaitRequest>(currentBranch(), REQUEST_TYPE);
+			if (!request) throw new Error("No active durable wait request");
+			return request;
+		};
+		const getOutcome = (): WaitOutcome | undefined => {
+			const request = getRequest();
+			return currentBranch?.()
+				.map((entry) => customData<WaitOutcome>(entry, OUTCOME_TYPE))
+				.find((outcome) => outcome?.requestId === request.requestId);
+		};
+		const recordOutcome = (outcome: WaitOutcome["outcome"]): RecordWaitOutcomeResult => {
+			const request = getRequest();
+			const existing = getOutcome();
+			if (existing) return { status: "conflict", outcome: existing };
+			const entry: WaitOutcome = { version: PACKAGE_VERSION, requestId: request.requestId, outcome };
+			pi.appendEntry(OUTCOME_TYPE, entry);
+			return { status: "recorded", outcome: entry };
+		};
+
+		if (controller) {
+			controller.respond = (value) => recordOutcome({ type: "response", value });
+			controller.cancel = (reason) => recordOutcome({ type: "cancellation", reason });
+			controller.getOutcome = getOutcome;
+		}
+		const stopResponseListener = pi.events.on(RESPONSE_EVENT, (data) => {
+			const value = typeof data === "string" ? data : "";
+			pi.events.emit(OUTCOME_RECORDED_EVENT, recordOutcome({ type: "response", value }));
+		});
+		const stopCancellationListener = pi.events.on(CANCELLATION_EVENT, (data) => {
+			const reason = typeof data === "string" ? data : "cancelled";
+			pi.events.emit(OUTCOME_RECORDED_EVENT, recordOutcome({ type: "cancellation", reason }));
+		});
+		pi.on("session_shutdown", () => {
+			stopResponseListener();
+			stopCancellationListener();
+		});
+
+		pi.registerTool({
+			name: "durable_wait",
+			label: "Durable Wait",
+			description: "Pause the Agent Thread durably until the user responds or continues without responding",
+			parameters: Type.Object({
+				prompt: Type.String({ description: "The input requested from the user" }),
+			}),
+			deferral: {
+				handlerId: "dev.pi.example.durable-wait",
+				handlerVersion: 1,
+				resumableHandlerVersions: [1],
+				inspectAvailability: ({ correlationId }, ctx) => {
+					const records = ctx.sessionManager.getBranch();
+					const request = records
+						.map((entry) => customData<WaitRequest>(entry, REQUEST_TYPE))
+						.find((entry) => entry?.requestId === correlationId);
+					const outcome = records
+						.map((entry) => customData<WaitOutcome>(entry, OUTCOME_TYPE))
+						.find((entry) => entry?.requestId === correlationId);
+					return (request?.version ?? outcome?.version) === PACKAGE_VERSION
+						? { status: "available" }
+						: {
+								status: "unavailable",
+								message: "The durable-wait package schema is incompatible with the persisted request.",
+								details: { supportedPackageVersions: [PACKAGE_VERSION] },
+							};
+				},
+				resolve: async (operation, _signal, ctx) => {
+					const branch = ctx.sessionManager.getBranch();
+					currentBranch = () => ctx.sessionManager.getBranch();
+					const assistant = findOwningAssistant(branch, operation.toolCallId);
+					let request = branch
+						.map((entry) => customData<WaitRequest>(entry, REQUEST_TYPE))
+						.find(
+							(entry) => entry?.assistantEntryId === assistant.id && entry.ownerCallId === operation.toolCallId,
+						);
+					if (!request) {
+						request = {
+							version: PACKAGE_VERSION,
+							requestId: `wait-${assistant.id}-${operation.toolCallId}`,
+							assistantEntryId: assistant.id,
+							ownerCallId: operation.toolCallId,
+							payload: { prompt: operation.params.prompt },
+						};
+						pi.appendEntry(REQUEST_TYPE, request);
+					}
+
+					const existingOutcome = getOutcome();
+					if (existingOutcome) {
+						return {
+							status: "ready",
+							disposition: existingOutcome.outcome.type === "response" ? "execute_batch" : "complete_owner",
+						};
+					}
+					if (operation.operation === "interrupt") {
+						recordOutcome({ type: "interruption", provenance: operation.provenance });
+						return { status: "ready", disposition: "complete_owner" };
+					}
+					if (operation.operation === "cancel") {
+						recordOutcome({ type: "cancellation", reason: operation.reason });
+						return { status: "ready", disposition: "complete_owner" };
+					}
+					return { status: "deferred", correlationId: request.requestId };
+				},
+				presenter: async (_snapshot, ctx) => {
+					if (ctx.mode !== "tui") return;
+					const request = getRequest();
+					const value = await ctx.ui.input("Waiting for user", request.payload.prompt);
+					if (value === undefined) return;
+					if (recordOutcome({ type: "response", value }).status === "recorded") {
+						void pi.resumeDeferred();
+					}
+				},
+			},
+			async execute(_toolCallId, _params, _signal, _onUpdate, ctx) {
+				currentBranch = () => ctx.sessionManager.getBranch();
+				const outcome = getOutcome();
+				if (!outcome) throw new Error("Durable wait outcome was not found");
+				const text =
+					outcome.outcome.type === "response"
+						? `Response: ${outcome.outcome.value}`
+						: outcome.outcome.type === "interruption"
+							? "Left unanswered"
+							: `Cancelled: ${outcome.outcome.reason}`;
+				return { content: [{ type: "text", text }], details: { outcome } };
+			},
+			renderCall(args, theme) {
+				return new Text(
+					`${theme.fg("toolTitle", theme.bold("durable_wait "))}${theme.fg("muted", args.prompt)}`,
+					0,
+					0,
+				);
+			},
+			renderResult(result, _options, theme) {
+				const text = result.content[0];
+				return new Text(theme.fg("accent", text?.type === "text" ? text.text : ""), 0, 0);
+			},
+		});
+	};
+}
+
+export default createDurableWaitExtension();
