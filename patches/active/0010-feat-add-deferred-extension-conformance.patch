@@ -0,0 +1,61 @@
+import { spawn } from "node:child_process";
+import { mkdtempSync, rmSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { dirname, join } from "node:path";
+import { fileURLToPath } from "node:url";
+import { afterEach, describe, expect, it } from "vitest";
+
+const roots: string[] = [];
+const packageDir = dirname(fileURLToPath(new URL("../../../package.json", import.meta.url)));
+const cliPath = join(packageDir, "dist", "cli.js");
+
+afterEach(() => {
+	while (roots.length > 0) rmSync(roots.pop()!, { recursive: true, force: true });
+});
+
+function runConformance(): Promise<{ code: number | null; stdout: string; stderr: string }> {
+	const root = mkdtempSync(join(tmpdir(), "pi-conformance-command-"));
+	roots.push(root);
+	return new Promise((resolve, reject) => {
+		const child = spawn(process.execPath, [cliPath, "conformance"], {
+			cwd: root,
+			env: {
+				...process.env,
+				PI_CODING_AGENT_DIR: join(root, "agent"),
+				PI_OFFLINE: "1",
+				NO_COLOR: "1",
+			},
+			stdio: ["ignore", "pipe", "pipe"],
+		});
+		let stdout = "";
+		let stderr = "";
+		child.stdout.setEncoding("utf8").on("data", (chunk) => {
+			stdout += chunk;
+		});
+		child.stderr.setEncoding("utf8").on("data", (chunk) => {
+			stderr += chunk;
+		});
+		child.on("error", reject);
+		child.on("close", (code) => resolve({ code, stdout, stderr }));
+	});
+}
+
+describe("pi conformance", () => {
+	it("runs the documented durable-deferral suite as an offline black box", async () => {
+		const result = await runConformance();
+
+		expect(result.code).toBe(0);
+		expect(result.stderr).toBe("");
+		expect(result.stdout.trim().split("\n")).toEqual([
+			"PASS stable deferral",
+			"PASS reload",
+			"PASS teardown/reopen",
+			"PASS Response",
+			"PASS Interruption",
+			"PASS Cancellation",
+			"PASS unavailability recovery",
+			"PASS abandonment",
+			"Deferred conformance passed (8/8)",
+		]);
+	});
+});
