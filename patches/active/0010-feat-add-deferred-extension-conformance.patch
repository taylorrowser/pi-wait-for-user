@@ -0,0 +1,261 @@
+import { mkdtempSync, rmSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { join } from "node:path";
+import { fauxAssistantMessage, fauxProvider, fauxToolCall } from "@earendil-works/pi-ai";
+import { getExamplesPath } from "./config.ts";
+import type { AgentSession } from "./core/agent-session.ts";
+import { createEventBus, type EventBus } from "./core/event-bus.ts";
+import { ModelRuntime } from "./core/model-runtime.ts";
+import { DefaultResourceLoader } from "./core/resource-loader.ts";
+import { createAgentSession } from "./core/sdk.ts";
+import { SessionManager } from "./core/session-manager.ts";
+import { SettingsManager } from "./core/settings-manager.ts";
+
+const RESPONSE_EVENT = "dev.pi.example.durable-wait/respond";
+const CANCELLATION_EVENT = "dev.pi.example.durable-wait/cancel";
+const OUTCOME_RECORDED_EVENT = "dev.pi.example.durable-wait/outcome-recorded";
+
+export interface DeferredConformanceResult {
+	passed: string[];
+	failed?: { check: string; message: string };
+}
+
+type Scenario = {
+	root: string;
+	faux: ReturnType<typeof fauxProvider>;
+	eventBus: ReturnType<typeof createEventBus>;
+	session: AgentSession;
+};
+
+function textOfLastToolResult(session: AgentSession): string | undefined {
+	const result = [...session.messages]
+		.reverse()
+		.find((message) => message.role === "toolResult" && message.toolName === "durable_wait");
+	if (!result || result.role !== "toolResult") return undefined;
+	return result.content.flatMap((content) => (content.type === "text" ? [content.text] : [])).join("\n");
+}
+
+function assert(condition: unknown, message: string): asserts condition {
+	if (!condition) throw new Error(message);
+}
+
+async function createScenario(
+	options: {
+		root?: string;
+		sessionManager?: SessionManager;
+		withExtension?: boolean;
+		faux?: ReturnType<typeof fauxProvider>;
+		eventBus?: ReturnType<typeof createEventBus>;
+	} = {},
+): Promise<Scenario> {
+	const root = options.root ?? mkdtempSync(join(tmpdir(), "pi-deferred-conformance-"));
+	const faux = options.faux ?? fauxProvider();
+	const eventBus = options.eventBus ?? createEventBus();
+	const settingsManager = SettingsManager.inMemory({ compaction: { enabled: false } });
+	const modelRuntime = await ModelRuntime.create({
+		authPath: join(root, "auth.json"),
+		modelsPath: null,
+		allowModelNetwork: false,
+	});
+	modelRuntime.registerNativeProvider(faux.provider);
+	await modelRuntime.refresh({ allowNetwork: false });
+	const resourceLoader = new DefaultResourceLoader({
+		cwd: root,
+		agentDir: join(root, "agent"),
+		settingsManager,
+		eventBus,
+		additionalExtensionPaths:
+			options.withExtension === false ? [] : [join(getExamplesPath(), "extensions", "durable-deferral.ts")],
+		noExtensions: true,
+		noSkills: true,
+		noPromptTemplates: true,
+		noThemes: true,
+		noContextFiles: true,
+	});
+	await resourceLoader.reload();
+	const extensionErrors = resourceLoader.getExtensions().errors;
+	if (extensionErrors.length > 0) throw new Error(extensionErrors.map((error) => error.error).join("; "));
+	const sessionManager = options.sessionManager ?? SessionManager.create(root, join(root, "sessions"));
+	const { session } = await createAgentSession({
+		cwd: root,
+		agentDir: join(root, "agent"),
+		model: faux.getModel(),
+		modelRuntime,
+		resourceLoader,
+		settingsManager,
+		sessionManager,
+		tools: options.withExtension === false ? [] : ["durable_wait"],
+	});
+	session.subscribe(() => {});
+	return { root, faux, eventBus, session };
+}
+
+async function defer(scenario: Scenario): Promise<void> {
+	scenario.faux.setResponses([
+		fauxAssistantMessage(fauxToolCall("durable_wait", { prompt: "Ship this change?" }, { id: "wait-1" }), {
+			stopReason: "toolUse",
+		}),
+	]);
+	await scenario.session.prompt("Ask before shipping");
+	assert(scenario.session.deferredBatch?.kind === "batch", "expected one Deferred Tool Batch");
+	assert(scenario.session.deferredBatch.phase === "deferred", "expected stable deferred phase");
+}
+
+function disposeScenario(scenario: Scenario, removeRoot = true): void {
+	scenario.session.dispose();
+	scenario.eventBus.clear();
+	if (removeRoot) rmSync(scenario.root, { recursive: true, force: true });
+}
+
+function recordOutcome(eventBus: EventBus, event: string, value: string): Promise<void> {
+	return new Promise((resolve, reject) => {
+		const timeout = setTimeout(() => {
+			stop();
+			reject(new Error("the example extension did not record the package outcome"));
+		}, 2_000);
+		const stop = eventBus.on(OUTCOME_RECORDED_EVENT, (data) => {
+			clearTimeout(timeout);
+			stop();
+			const status = (data as { status?: unknown } | undefined)?.status;
+			if (status !== "recorded") {
+				reject(new Error(`package outcome was not recorded: ${String(status)}`));
+				return;
+			}
+			resolve();
+		});
+		eventBus.emit(event, value);
+	});
+}
+
+export async function runDeferredConformance(
+	report: (line: string) => void = (line) => console.log(line),
+): Promise<DeferredConformanceResult> {
+	const passed: string[] = [];
+	const activeScenarios = new Set<Scenario>();
+	let currentCheck = "stable deferral";
+	const pass = (check: string) => {
+		passed.push(check);
+		report(`PASS ${check}`);
+	};
+	const open = async (options: Parameters<typeof createScenario>[0] = {}) => {
+		const scenario = await createScenario(options);
+		activeScenarios.add(scenario);
+		return scenario;
+	};
+	const close = (scenario: Scenario, removeRoot = true) => {
+		if (!activeScenarios.delete(scenario)) return;
+		disposeScenario(scenario, removeRoot);
+	};
+
+	try {
+		const stable = await open();
+		await defer(stable);
+		assert(stable.session.isIdle, "deferred Agent Thread must be settled");
+		assert(!stable.session.isStreaming, "deferred Agent Thread must not be streaming");
+		pass("stable deferral");
+
+		currentCheck = "reload";
+		const beforeReload = stable.session.deferredBatch;
+		await stable.session.reload();
+		assert(
+			JSON.stringify(stable.session.deferredBatch) === JSON.stringify(beforeReload),
+			"reload changed deferred state",
+		);
+		pass("reload");
+
+		currentCheck = "teardown/reopen";
+		const sessionFile = stable.session.sessionFile;
+		assert(sessionFile, "persistent conformance session has no file");
+		const stableRoot = stable.root;
+		close(stable, false);
+		const reopened = await open({
+			root: stableRoot,
+			sessionManager: SessionManager.open(sessionFile),
+		});
+		assert(reopened.session.deferredBatch?.kind === "batch", "reopen lost deferred state");
+		assert(reopened.session.deferredBatch.phase === "deferred", "reopen changed deferred phase");
+		pass("teardown/reopen");
+		close(reopened);
+
+		currentCheck = "Response";
+		const response = await open();
+		await defer(response);
+		await recordOutcome(response.eventBus, RESPONSE_EVENT, "yes");
+		response.faux.setResponses([fauxAssistantMessage("continued after Response")]);
+		const responseResult = await response.session.resumeDeferred();
+		assert(responseResult.status === "advanced", "Response did not advance the Agent Thread");
+		assert(textOfLastToolResult(response.session) === "Response: yes", "Response result was not package-owned");
+		pass("Response");
+		close(response);
+
+		currentCheck = "Interruption";
+		const interruption = await open();
+		await defer(interruption);
+		interruption.faux.setResponses([fauxAssistantMessage("continued after Interruption")]);
+		await interruption.session.prompt("Continue without answering");
+		assert(interruption.session.deferredBatch === undefined, "Interruption left deferred state active");
+		assert(textOfLastToolResult(interruption.session) === "Left unanswered", "Interruption result was not typed");
+		pass("Interruption");
+		close(interruption);
+
+		currentCheck = "Cancellation";
+		const cancellation = await open();
+		await defer(cancellation);
+		await recordOutcome(cancellation.eventBus, CANCELLATION_EVENT, "declined");
+		cancellation.faux.setResponses([fauxAssistantMessage("continued after Cancellation")]);
+		const cancellationResult = await cancellation.session.abandonDeferred();
+		assert(cancellationResult.status === "advanced", "Cancellation did not advance the Agent Thread");
+		assert(textOfLastToolResult(cancellation.session) === "Cancelled: declined", "Cancellation result was not typed");
+		pass("Cancellation");
+		close(cancellation);
+
+		currentCheck = "unavailability recovery";
+		const initial = await open();
+		await defer(initial);
+		const unavailableFile = initial.session.sessionFile;
+		const unavailableRoot = initial.root;
+		assert(unavailableFile, "unavailability session has no file");
+		close(initial, false);
+		const unavailable = await open({
+			root: unavailableRoot,
+			sessionManager: SessionManager.open(unavailableFile),
+			withExtension: false,
+		});
+		assert(
+			unavailable.session.deferredBatch?.kind === "batch" &&
+				unavailable.session.deferredBatch.availability.status === "unavailable",
+			"missing extension was not reported as unavailable",
+		);
+		close(unavailable, false);
+		const restored = await open({
+			root: unavailableRoot,
+			sessionManager: SessionManager.open(unavailableFile),
+		});
+		assert(
+			restored.session.deferredBatch?.kind === "batch" &&
+				restored.session.deferredBatch.availability.status === "available",
+			"restoring compatible code did not recover availability",
+		);
+		pass("unavailability recovery");
+		close(restored);
+
+		currentCheck = "abandonment";
+		const abandonment = await open();
+		await defer(abandonment);
+		abandonment.faux.setResponses([fauxAssistantMessage("continued after abandonment")]);
+		const abandonResult = await abandonment.session.abandonDeferred();
+		assert(abandonResult.status === "advanced", "abandonment did not advance the Agent Thread");
+		assert(textOfLastToolResult(abandonment.session) === "Cancelled: abandoned", "abandonment was not typed");
+		pass("abandonment");
+		close(abandonment);
+
+		report(`Deferred conformance passed (${passed.length}/${passed.length})`);
+		return { passed };
+	} catch (error) {
+		const message = error instanceof Error ? error.message : String(error);
+		report(`FAIL ${currentCheck}: ${message}`);
+		return { passed, failed: { check: currentCheck, message } };
+	} finally {
+		for (const scenario of activeScenarios) disposeScenario(scenario);
+	}
+}
