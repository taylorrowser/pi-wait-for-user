diff --git a/packages/coding-agent/test/suite/deferred-tool-batch-fixture.ts b/packages/coding-agent/test/suite/deferred-tool-batch-fixture.ts
new file mode 100644
index 00000000..d3668ad2
--- /dev/null
+++ b/packages/coding-agent/test/suite/deferred-tool-batch-fixture.ts
@@ -0,0 +1,154 @@
+import { fauxAssistantMessage, fauxToolCall } from "@earendil-works/pi-ai";
+import { Type } from "typebox";
+import type { ExtensionFactory } from "../../src/core/extensions/index.ts";
+import type { SessionEntry } from "../../src/core/session-manager.ts";
+
+export const requestType = "dev.example.question/request";
+export const outcomeType = "dev.example.question/outcome";
+
+type QuestionInteractionRequest = {
+	version: 1;
+	requestId: string;
+	assistantEntryId: string;
+	ownerCallId: string;
+	payload: { question: string };
+};
+
+type QuestionOutcome = {
+	version: 1;
+	requestId: string;
+	outcome: { type: "response"; value: string };
+};
+
+type RecordResponseResult =
+	| { status: "recorded"; outcome: QuestionOutcome }
+	| { status: "conflict"; outcome: QuestionOutcome };
+
+export type InteractionRequestTestController = {
+	recordResponse?: (value: string) => RecordResponseResult;
+	resolverFailure?: "malformed" | "throw";
+};
+
+function customData<T>(entry: SessionEntry, customType: string): T | undefined {
+	return entry.type === "custom" && entry.customType === customType ? (entry.data as T) : undefined;
+}
+
+function findLastCustomData<T>(branch: SessionEntry[], customType: string): T | undefined {
+	for (let index = branch.length - 1; index >= 0; index--) {
+		const data = customData<T>(branch[index], customType);
+		if (data) return data;
+	}
+	return undefined;
+}
+
+export function deferredToolBatchMessage() {
+	return fauxAssistantMessage(
+		[
+			fauxToolCall("ordinary", { question: "Prepare?" }, { id: "call-0" }),
+			fauxToolCall("question", { question: "Ship?" }, { id: "call-1" }),
+			fauxToolCall("ordinary", { question: "Deploy?" }, { id: "call-2" }),
+		],
+		{ stopReason: "toolUse" },
+	);
+}
+
+export function questionExtension(
+	executions: string[],
+	controller?: InteractionRequestTestController,
+	options: { includeOrdinary?: boolean } = {},
+): ExtensionFactory {
+	return (pi) => {
+		let currentBranch: (() => SessionEntry[]) | undefined;
+		if (controller) {
+			controller.recordResponse = (value) => {
+				const branch = currentBranch?.();
+				if (!branch) throw new Error("Interaction Request is not active");
+				const request = findLastCustomData<QuestionInteractionRequest>(branch, requestType);
+				if (!request) throw new Error("Interaction Request was not found");
+				const existing = branch
+					.map((entry) => customData<QuestionOutcome>(entry, outcomeType))
+					.find((entry) => entry?.requestId === request.requestId);
+				if (existing) return { status: "conflict", outcome: existing };
+				const outcome: QuestionOutcome = {
+					version: 1,
+					requestId: request.requestId,
+					outcome: { type: "response", value },
+				};
+				pi.appendEntry(outcomeType, outcome);
+				return { status: "recorded", outcome };
+			};
+		}
+
+		if (options.includeOrdinary !== false) {
+			pi.registerTool({
+				name: "ordinary",
+				label: "Ordinary",
+				description: "Run ordinary work after the Response",
+				parameters: Type.Object({ question: Type.String() }),
+				async execute(_toolCallId, params) {
+					executions.push(`ordinary:${params.question}`);
+					return { content: [{ type: "text", text: `Completed: ${params.question}` }], details: {} };
+				},
+			});
+		}
+
+		pi.registerTool({
+			name: "question",
+			label: "Question",
+			description: "Wait for a Response",
+			parameters: Type.Object({ question: Type.String() }),
+			deferral: {
+				handlerId: "dev.example.question",
+				handlerVersion: 1,
+				resumableHandlerVersions: [1],
+				resolve: async (request, _signal, ctx) => {
+					currentBranch = () => ctx.sessionManager.getBranch();
+					const branch = currentBranch();
+					let assistantEntry: SessionEntry | undefined;
+					for (let index = branch.length - 1; index >= 0; index--) {
+						const entry = branch[index];
+						if (
+							entry.type === "message" &&
+							entry.message.role === "assistant" &&
+							entry.message.content.some(
+								(content) => content.type === "toolCall" && content.id === request.toolCallId,
+							)
+						) {
+							assistantEntry = entry;
+							break;
+						}
+					}
+					if (!assistantEntry) throw new Error("owning assistant entry not found");
+					const existingInteractionRequest = branch
+						.map((entry) => customData<QuestionInteractionRequest>(entry, requestType))
+						.find((entry) => entry?.ownerCallId === request.toolCallId);
+					const requestId = existingInteractionRequest?.requestId ?? "request-1";
+					const outcome = branch
+						.map((entry) => customData<QuestionOutcome>(entry, outcomeType))
+						.find((entry) => entry?.requestId === requestId);
+					if (outcome?.outcome.type === "response") {
+						return { status: "ready", disposition: "execute_batch" };
+					}
+					if (!existingInteractionRequest) {
+						pi.appendEntry(requestType, {
+							version: 1,
+							requestId,
+							assistantEntryId: assistantEntry.id,
+							ownerCallId: request.toolCallId,
+							payload: { question: request.params.question },
+						} satisfies QuestionInteractionRequest);
+					}
+					if (controller?.resolverFailure === "throw") throw new Error("package failed");
+					if (controller?.resolverFailure === "malformed") return { status: "invalid" } as never;
+					return { status: "deferred", correlationId: requestId };
+				},
+			},
+			async execute(_toolCallId, params, _signal, _onUpdate, ctx) {
+				const outcome = findLastCustomData<QuestionOutcome>(ctx.sessionManager.getBranch(), outcomeType);
+				if (!outcome) throw new Error("Response was not found");
+				executions.push(params.question);
+				return { content: [{ type: "text", text: outcome.outcome.value }], details: {} };
+			},
+		});
+	};
+}
