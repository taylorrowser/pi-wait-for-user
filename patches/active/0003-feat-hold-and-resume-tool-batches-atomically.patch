+export class ToolDeferralResolverError extends Error {
+	readonly code = "resolver_error";
+}
+
+async function invokeToolDeferralResolver<TParams>(
+	capability: AgentToolDeferral<TParams>,
+	request: EvaluateToolDeferralRequest<TParams>,
+	signal: AbortSignal | undefined,
+): Promise<ToolDeferralResolution> {
+	if (signal?.aborted) throw new ToolDeferralResolverError("Tool deferral resolver aborted");
+	let onAbort: (() => void) | undefined;
+	const aborted = new Promise<never>((_resolve, reject) => {
+		onAbort = () => reject(new ToolDeferralResolverError("Tool deferral resolver aborted"));
+		signal?.addEventListener("abort", onAbort, { once: true });
+	});
+	let resolution: unknown;
+	try {
+		resolution = await Promise.race([capability.resolve(request, signal), aborted]);
+	} catch (error) {
+		if (error instanceof ToolDeferralResolverError) throw error;
+		throw new ToolDeferralResolverError(
+			`Tool deferral resolver failed: ${error instanceof Error ? error.message : String(error)}`,
+		);
+	} finally {
+		if (onAbort) signal?.removeEventListener("abort", onAbort);
+	}
+	if (signal?.aborted) throw new ToolDeferralResolverError("Tool deferral resolver aborted");
+	if (!resolution || typeof resolution !== "object" || !("status" in resolution)) {
+		throw new ToolDeferralResolverError("Tool deferral resolver returned a malformed result");
+	}
+	if (
+		resolution.status === "ready" &&
+		"disposition" in resolution &&
+		(resolution.disposition === "execute_batch" || resolution.disposition === "complete_owner")
+	) {
+		return { status: "ready", disposition: resolution.disposition };
+	}
+	if (
+		resolution.status === "deferred" &&
+		"correlationId" in resolution &&
+		typeof resolution.correlationId === "string" &&
+		resolution.correlationId.length > 0
+	) {
+		return { status: "deferred", correlationId: resolution.correlationId };
+	}
+	if (resolution.status === "unavailable" && "reason" in resolution && typeof resolution.reason === "string") {
+		return { status: "unavailable", reason: resolution.reason };
+	}
+	throw new ToolDeferralResolverError("Tool deferral resolver returned a malformed result");
+}
