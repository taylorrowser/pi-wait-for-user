+import { mkdtempSync, readFileSync, rmSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { join } from "node:path";
+import { fauxAssistantMessage, fauxToolCall } from "@earendil-works/pi-ai";
+import { afterEach, describe, expect, it } from "vitest";
+import { SessionManager } from "../../../src/core/session-manager.ts";
+import {
+	deferredToolBatchMessage,
+	type InteractionRequestTestController,
+	questionExtension,
+} from "../deferred-tool-batch-fixture.ts";
+import { createHarness, type Harness } from "../harness.ts";
+
+describe("regression #15: atomic deferred tool batches", () => {
+	const harnesses: Harness[] = [];
+	const roots: string[] = [];
+
+	afterEach(() => {
+		while (harnesses.length > 0) harnesses.pop()?.cleanup();
+		while (roots.length > 0) rmSync(roots.pop()!, { recursive: true, force: true });
+	});
+
+	it("leaves the assistant batch recoverable when resolver validation fails after Interaction Request persistence", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-resolver-error-"));
+		roots.push(root);
+		const manager = SessionManager.create(root, join(root, "sessions"));
+		const executions: string[] = [];
+		const controller: InteractionRequestTestController = { resolverFailure: "malformed" };
+		const harness = await createHarness({
+			sessionManager: manager,
+			extensionFactories: [questionExtension(executions, controller)],
+		});
+		harnesses.push(harness);
+		harness.setResponses([
+			fauxAssistantMessage(fauxToolCall("question", { question: "Ship?" }, { id: "call-1" }), {
+				stopReason: "toolUse",
+			}),
+		]);
+
+		await expect(harness.session.prompt("Ask before shipping")).rejects.toMatchObject({ code: "resolver_error" });
+
+		expect(executions).toEqual([]);
+		expect(harness.getPendingResponseCount()).toBe(0);
+		expect(manager.getBranch().map((entry) => entry.type)).toEqual(["message", "message", "custom"]);
+		expect(manager.getBranch().flatMap((entry) => (entry.type === "message" ? [entry.message.role] : []))).toEqual([
+			"user",
+			"assistant",
+		]);
+		expect(harness.events.some((event) => event.type === "tool_execution_start")).toBe(false);
+		expect(harness.events.some((event) => event.type === "turn_end")).toBe(false);
+		expect(harness.events.map((event) => event.type).slice(-2)).toEqual(["agent_end", "agent_settled"]);
+	});
+
+	it("preserves typed resolver failures from explicit resume", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-resume-resolver-error-"));
+		roots.push(root);
+		const manager = SessionManager.create(root, join(root, "sessions"));
+		const controller: InteractionRequestTestController = {};
+		const harness = await createHarness({
+			sessionManager: manager,
+			extensionFactories: [questionExtension([], controller)],
+		});
+		harnesses.push(harness);
+		harness.setResponses([
+			fauxAssistantMessage(fauxToolCall("question", { question: "Ship?" }, { id: "call-1" }), {
+				stopReason: "toolUse",
+			}),
+		]);
+		await harness.session.prompt("Ask before shipping");
+		const bytesBeforeResume = readFileSync(manager.getSessionFile()!, "utf8");
+		controller.resolverFailure = "malformed";
+
+		await expect(harness.session.resumeDeferred()).rejects.toMatchObject({ code: "resolver_error" });
+
+		expect(readFileSync(manager.getSessionFile()!, "utf8")).toBe(bytesBeforeResume);
+		expect(harness.session.deferredBatch?.phase).toBe("deferred");
+	});
+
+	it("does not mutate a Deferred Tool Batch after a Response when a sibling is missing", async () => {
+		const root = mkdtempSync(join(tmpdir(), "pi-deferred-missing-sibling-"));
+		roots.push(root);
+		const manager = SessionManager.create(root, join(root, "sessions"));
+		const controller: InteractionRequestTestController = {};
+		const initial = await createHarness({
+			sessionManager: manager,
+			extensionFactories: [questionExtension([], controller)],
+		});
+		harnesses.push(initial);
+		initial.setResponses([deferredToolBatchMessage()]);
+		await initial.session.prompt("Ask before shipping");
+		controller.recordResponse?.("Yes");
+		const sessionFile = manager.getSessionFile()!;
+		const bytesBeforeResume = readFileSync(sessionFile, "utf8");
+		initial.cleanup();
+		harnesses.pop();
+
+		const reopened = await createHarness({
+			sessionManager: SessionManager.open(sessionFile),
+			extensionFactories: [questionExtension([], undefined, { includeOrdinary: false })],
+		});
+		harnesses.push(reopened);
+
+		await expect(reopened.session.resumeDeferred()).rejects.toThrow(/Tool ordinary not found/);
+
+		expect(readFileSync(sessionFile, "utf8")).toBe(bytesBeforeResume);
+		expect(reopened.session.deferredBatch?.phase).toBe("deferred");
+		expect(reopened.getPendingResponseCount()).toBe(0);
+	});
+});
