+				this.createContextSnapshot(),
+				this.createLoopConfig(),
+				(event) => this.processEvents(event),
+				signal,
+				this.streamFunction,
+			),
+		);
+		if (result === undefined) throw new Error("Deferred tool-batch resume failed");
+		return result;
+	}
