+/** Rebind and advance one persisted deferred tool call from the current transcript. */
+export async function runAgentLoopResume(
+	deferred: DeferredToolBatchResume,
+	context: AgentContext,
+	initialConfig: AgentLoopConfig,
+	emit: AgentEventSink,
+	signal: AbortSignal | undefined,
+	streamFn: StreamFn,
+): Promise<DeferredToolBatchResumeStatus> {
+	let currentContext: AgentContext = { ...context, messages: [...context.messages] };
+	const newMessages: AgentMessage[] = [];
+	let config = initialConfig;
+	let assistantMessage: AssistantMessage | undefined;
+	for (let index = currentContext.messages.length - 1; index >= 0; index--) {
+		const message = currentContext.messages[index];
+		if (
+			message.role === "assistant" &&
+			message.content.some((content) => content.type === "toolCall" && content.id === deferred.ownerCallId)
+		) {
+			assistantMessage = message;
+			break;
+		}
+	}
+	if (!assistantMessage) throw new Error(`Deferred owner call ${deferred.ownerCallId} was not found`);
+	const toolCalls = assistantMessage.content.filter((content) => content.type === "toolCall");
+	if (toolCalls.length !== 1 || toolCalls[0].id !== deferred.ownerCallId) {
+		throw new Error("Deferred resume currently requires the original single-call batch");
+	}
+	const toolCall = toolCalls[0];
+	const tool = currentContext.tools?.find((candidate) => candidate.name === toolCall.name);
+	const capability = tool?.deferral;
+	if (
+		!tool ||
+		!capability ||
+		capability.handlerId !== deferred.handlerId ||
+		!capability.resumableHandlerVersions.includes(deferred.handlerVersion)
+	) {
+		throw new Error(`Deferred owner call ${deferred.ownerCallId} is unavailable`);
+	}
+	const preparedToolCall = prepareToolCallArguments(tool, toolCall);
+	const preparation: PreparedToolCall = {
+		kind: "prepared",
+		toolCall,
+		tool,
+		args: validateToolArguments(tool, preparedToolCall),
+	};
+
+	await emit({ type: "agent_start" });
+	const resolution = await capability.resolve(
+		{
+			operation: "evaluate",
+			toolCallId: toolCall.id,
+			params: preparation.args,
+			persistedHandlerVersion: deferred.handlerVersion,
+		},
+		signal,
+	);
+	if (resolution.status === "deferred") {
+		if (resolution.correlationId !== deferred.correlationId) {
+			throw new Error(`Deferred owner call ${deferred.ownerCallId} returned a conflicting correlation`);
+		}
+		await emit({ type: "agent_end", messages: newMessages });
+		return "still_deferred";
+	}
+	if (resolution.status === "unavailable") throw new Error(resolution.reason);
+	if (resolution.disposition !== "execute_batch") {
+		throw new Error(`Deferred owner call ${deferred.ownerCallId} cannot complete through batch execution`);
+	}
+
+	const executed = await executeToolCallsSequential(
+		currentContext,
+		assistantMessage,
+		toolCalls,
+		config,
+		signal,
+		emit,
+		preparation,
+	);
+	if (executed.status !== "completed") throw new Error("Deferred tool call unexpectedly deferred again");
+	for (const result of executed.messages) {
+		currentContext.messages.push(result);
+		newMessages.push(result);
+	}
+	await emit({ type: "turn_end", message: assistantMessage, toolResults: executed.messages });
+
+	const nextTurnContext = {
+		message: assistantMessage,
+		toolResults: executed.messages,
+		context: currentContext,
+		newMessages,
+	};
+	const nextTurnSnapshot = await config.prepareNextTurn?.(nextTurnContext);
+	if (nextTurnSnapshot) {
+		currentContext = nextTurnSnapshot.context ?? currentContext;
+		config = {
+			...config,
+			model: nextTurnSnapshot.model ?? config.model,
+			reasoning:
+				nextTurnSnapshot.thinkingLevel === undefined
+					? config.reasoning
+					: nextTurnSnapshot.thinkingLevel === "off"
+						? undefined
+						: nextTurnSnapshot.thinkingLevel,
+		};
+	}
+	if (executed.terminate || (await config.shouldStopAfterTurn?.({ ...nextTurnContext, context: currentContext }))) {
+		await emit({ type: "agent_end", messages: newMessages });
+		return "advanced";
+	}
+
+	await emit({ type: "turn_start" });
+	await runLoop(currentContext, newMessages, config, signal, emit, streamFn ?? getDefaultStreamFn());
+	return "advanced";
+}
+
