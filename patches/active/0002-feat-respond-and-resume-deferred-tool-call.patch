+	/** Explicitly rebind and advance the active deferred tool batch. */
+	async resumeDeferred(): Promise<ResumeDeferredResult> {
+		const snapshot = this.deferredBatch;
+		if (!snapshot) return { status: "none", deferredBatch: undefined };
+		if (!this.isIdle)
+			throw new Error("Agent is already processing. Wait for completion before resuming deferred work.");
+		if (snapshot.phase === "markerless") return { status: "still_deferred", deferredBatch: snapshot };
+		const marker = this.sessionManager
+			.getBranch()
+			.find((entry) => entry.type === "tool_batch_deferred" && entry.assistantEntryId === snapshot.assistantEntryId);
+		if (!marker || marker.type !== "tool_batch_deferred") {
+			return { status: "still_deferred", deferredBatch: snapshot };
+		}
+
+		this._isAgentRunActive = true;
+		let status: "still_deferred" | "advanced";
+		try {
+			status = await this.agent.resumeDeferredToolBatch({
+				ownerCallId: marker.ownerCallId,
+				correlationId: marker.correlationId,
+				handlerId: marker.handlerId,
+				handlerVersion: marker.handlerVersion,
+			});
+			while (await this._handlePostAgentRun()) {
+				await this.agent.continue();
+			}
+		} finally {
+			this._systemPromptOverride = undefined;
+			this._flushPendingBashMessages();
+			await this._emitAgentSettled();
+		}
+		return { status, deferredBatch: this.deferredBatch };
+	}
+
 	/** Current retry attempt (0 if not retrying) */
 	get retryAttempt(): number {
 		return this._retryAttempt;
