{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/taylorrowser/pi-wait-for-user/main/releases/schemas/release-channel-v1.schema.json",
  "title": "Release Channel v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["signed", "signatures"],
  "properties": {
    "signed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "type", "sequence", "expires", "manifest"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "type": { "const": "release-channel" },
        "sequence": { "type": "integer", "minimum": 1 },
        "expires": { "type": "string", "format": "date-time" },
        "manifest": {
          "type": "object",
          "additionalProperties": false,
          "required": ["releaseId", "url", "sha256"],
          "properties": {
            "releaseId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]+$" },
            "url": { "type": "string", "format": "uri", "pattern": "^https://" },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        }
      }
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["keyId", "algorithm", "signature"],
        "properties": {
          "keyId": { "type": "string" },
          "algorithm": { "const": "ed25519" },
          "signature": { "type": "string", "contentEncoding": "base64" }
        }
      }
    }
  }
}
