{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/taylorrowser/pi-wait-for-user/main/releases/schemas/release-manifest-v1.schema.json",
  "title": "Release Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["signed", "signatures"],
  "properties": {
    "signed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "type", "releaseId", "tag", "publishedAt", "upstream", "patches", "compatibility", "manager", "bootstrap", "platformArchives", "releaseGates", "provenance", "releaseNotes"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "type": { "const": "release-manifest" },
        "releaseId": { "$ref": "#/$defs/releaseId" },
        "tag": { "$ref": "#/$defs/releaseId" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "upstream": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "tag", "commit", "packageVersion"],
          "properties": {
            "repository": { "type": "string", "format": "uri", "pattern": "^https://" },
            "tag": { "type": "string", "minLength": 1 },
            "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
            "packageVersion": { "type": "string", "minLength": 1 }
          }
        },
        "patches": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/patch" } },
        "compatibility": { "$ref": "#/$defs/compatibility" },
        "manager": {
          "type": "object",
          "additionalProperties": false,
          "required": ["releaseId", "compatibleReleaseManifestVersions", "artifacts"],
          "properties": {
            "releaseId": { "$ref": "#/$defs/releaseId" },
            "compatibleReleaseManifestVersions": { "type": "array", "minItems": 1, "items": { "type": "integer", "minimum": 1 } },
            "artifacts": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifact" } }
          }
        },
        "bootstrap": {
          "type": "object",
          "additionalProperties": false,
          "required": ["installer"],
          "properties": { "installer": { "$ref": "#/$defs/artifact" } }
        },
        "platformArchives": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/platformArchive" } },
        "releaseGates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "status", "definition", "report"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "status": { "const": "passed" },
              "definition": { "$ref": "#/$defs/artifact" },
              "report": { "$ref": "#/$defs/artifact" }
            }
          }
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "workflow", "sourceCommit", "artifacts"],
          "properties": {
            "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
            "workflow": { "$ref": "#/$defs/path" },
            "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
            "artifacts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "sha256"],
                "properties": {
                  "name": { "$ref": "#/$defs/path" },
                  "sha256": { "$ref": "#/$defs/sha256" }
                }
              }
            }
          }
        },
        "releaseNotes": { "$ref": "#/$defs/artifact" }
      }
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["keyId", "algorithm", "signature"],
        "properties": {
          "keyId": { "type": "string" },
          "algorithm": { "const": "ed25519" },
          "signature": { "type": "string", "contentEncoding": "base64" }
        }
      }
    }
  },
  "$defs": {
    "releaseId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]+$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "path": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$" },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sha256", "size"],
      "properties": {
        "name": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size": { "type": "integer", "minimum": 0 }
      }
    },
    "patch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["order", "path", "sha256", "size"],
      "properties": {
        "order": { "type": "integer", "minimum": 1 },
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size": { "type": "integer", "minimum": 0 }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["questionTool", "sessions"],
      "properties": {
        "questionTool": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "manifest", "package", "coreProtocolVersions", "handlerId", "handlerVersion", "packageSchemaVersions"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "manifest": { "$ref": "#/$defs/artifact" },
            "package": { "$ref": "#/$defs/artifact" },
            "coreProtocolVersions": { "$ref": "#/$defs/versions" },
            "handlerId": { "type": "string", "minLength": 1 },
            "handlerVersion": { "type": "integer", "minimum": 1 },
            "packageSchemaVersions": { "$ref": "#/$defs/versions" }
          }
        },
        "sessions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["identities", "readableCoreProtocolVersions", "readableHandlers"],
          "properties": {
            "identities": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "version"],
                "properties": { "id": { "type": "string", "minLength": 1 }, "version": { "type": "integer", "minimum": 1 } }
              }
            },
            "readableCoreProtocolVersions": { "$ref": "#/$defs/versions" },
            "readableHandlers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "versions"],
                "properties": { "id": { "type": "string", "minLength": 1 }, "versions": { "$ref": "#/$defs/versions" } }
              }
            }
          }
        }
      }
    },
    "versions": { "type": "array", "minItems": 1, "items": { "type": "integer", "minimum": 1 } },
    "payloadFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size", "mode"],
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size": { "type": "integer", "minimum": 0 },
        "mode": { "type": "integer", "minimum": 0, "maximum": 511 }
      }
    },
    "platformArchive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "artifact", "payload"],
      "properties": {
        "platform": { "type": "string", "pattern": "^[a-z0-9]+-(arm64|x64)$" },
        "artifact": { "$ref": "#/$defs/artifact" },
        "payload": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/payloadFile" } }
      }
    }
  }
}
